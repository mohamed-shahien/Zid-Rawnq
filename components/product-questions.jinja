{% if questions is defined and questions is not none and questions.results is defined and questions.results | length > 0 %}
  <!-- Populated State: Questions Exist -->
  <div class="questions-luxury-container">
    <div class="questions-luxury-header d-flex justify-content-between align-items-center mb-4">
      <button type="button" class="btn-add-question-luxury" id="addQuestionButton">
        <span>{{ _("Add your question") }}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="16"></line>
          <line x1="8" y1="12" x2="16" y2="12"></line>
        </svg>
      </button>
      <h3 class="questions-luxury-title">{{ _("Question") }}</h3>
    </div>

    <div class="questions-luxury-list">
      {% for question in questions.results %}
        <div class="questions-luxury-card">
          <div class="questions-luxury-card-header d-flex justify-content-between align-items-center"
            role="button" tabindex="0" aria-expanded="true"
            aria-controls="product-question-body-{{ loop.index0 }}" style="cursor: pointer;">
            <span class="customer-name">
              {% if not question.is_anonymous and question.name is defined and question.name is not none %}
                {{ question.name }}
              {% else %}
                {{ _("Anonymous") }}
              {% endif %}
            </span>
            <span class="questions-luxury-toggle-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <line x1="12" y1="5" x2="12" y2="19" class="vertical-line"></line>
              </svg>
            </span>
          </div>
          <div class="questions-luxury-card-body" id="product-question-body-{{ loop.index0 }}">
            <h4 class="question-text">{{ question.question }}</h4>
            {% if question.answers is defined and question.answers is not none and question.answers | length > 0 %}
              <p class="answer-text">{{ question.answers[0].answer }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if questions.count >= 5 %}
      <div class="text-center mt-4 questions-view_more">
        <a href="{{ url_for('product_questions', slug=product.id) }}" class="btn-view-all-questions">
          {{ _("View all questions") }}
        </a>
      </div>
    {% endif %}
  </div>
  
  <script>
    (function() {
      var reduceMotion = window.matchMedia
        && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      document.querySelectorAll('.questions-luxury-card-header').forEach(function(header) {
        if (header.__questionAccordionBound) {
          return;
        }

        header.__questionAccordionBound = true;
        header.addEventListener('click', handleHeaderClick);
        header.addEventListener('keydown', function(event) {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            handleHeaderClick({ currentTarget: header });
          }
        });
      });

      function handleHeaderClick(e) {
        var card = e.currentTarget.closest('.questions-luxury-card');
        var body = card && card.querySelector('.questions-luxury-card-body');
        if (!card || !body) {
          return;
        }

        var shouldOpen = card.classList.contains('collapsed');
        e.currentTarget.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');

        if (reduceMotion) {
          card.classList.toggle('collapsed', !shouldOpen);
          body.style.maxHeight = shouldOpen ? 'none' : '0px';
          return;
        }

        body.style.maxHeight = body.scrollHeight + 'px';
        void body.offsetHeight;

        if (shouldOpen) {
          card.classList.remove('collapsed');
          body.style.maxHeight = body.scrollHeight + 'px';
          body.addEventListener('transitionend', function resetOpenHeight(event) {
            if (event.propertyName === 'max-height' && !card.classList.contains('collapsed')) {
              body.style.maxHeight = 'none';
              body.removeEventListener('transitionend', resetOpenHeight);
            }
          });
        } else {
          card.classList.add('collapsed');
          body.style.maxHeight = '0px';
        }
      }
    })();
  </script>
{% else %}
  <!-- Empty State: No Questions -->
  <div class="questions-luxury-empty-wrapper">
    <div class="questions-luxury-empty">
      <div class="image-box">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Paper Document -->
          <rect x="14" y="10" width="36" height="44" rx="2" stroke="black" stroke-width="2" fill="none"/>
          <!-- Document lines -->
          <line x1="20" y1="22" x2="32" y2="22" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <line x1="20" y1="30" x2="44" y2="30" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <line x1="20" y1="38" x2="44" y2="38" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <line x1="20" y1="46" x2="36" y2="46" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <!-- Question box at top-right -->
          <rect x="36" y="6" width="16" height="16" rx="1" fill="black"/>
          <!-- White question mark -->
          <text x="44" y="18" fill="white" font-family="sans-serif" font-size="12" font-weight="bold" text-anchor="middle">?</text>
        </svg>
      </div>
      <p class="empty-title m-0">{{ _("There are no previous questions") }}</p>
      <p class="empty-desc m-0">{{ _("You can add your question to know more about the product") }}</p>
      <div class="button-box mt-3">
        <button type="button" class="btn-add-question-luxury" id="addQuestionButton">
          <span>{{ _("Add your question") }}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="16"></line>
            <line x1="8" y1="12" x2="16" y2="12"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>
{% endif %}
