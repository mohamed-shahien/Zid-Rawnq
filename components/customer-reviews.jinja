<div class="reviews-luxury-header d-flex justify-content-between align-items-center mb-4">
  <div class="reviews-luxury-summary">
    {% set reviews_count = product.rating.total_count if (product.rating and product.rating.total_count) else (reviews | length if reviews else (12 if dev else 0)) %}
    {% set rating_val = product.rating.average if (product.rating and product.rating.average) else (5.0 if (reviews_count > 0 or dev) else 0.0) %}
    <div class="d-flex align-items-baseline gap-2">
      <span class="reviews-luxury-score">{{ rating_val | round(1) }}</span>
      <span class="reviews-luxury-count-label text-muted">
        {% if session.lang == 'ar' %}
          بناءً على {{ reviews_count }} تقييم
        {% else %}
          Based on {{ reviews_count }} reviews
        {% endif %}
      </span>
    </div>
    <div class="reviews-luxury-stars mt-1">
      {% set rating = rating_val %}
      {% include 'components/rating-stars.jinja' %}
    </div>
  </div>

  <div class="reviews-luxury-actions">
    {% if session.is_guest %}
      <a href="/auth/login?redirect_to={{ url_for('add_product_review', slug=product.id) }}"
         class="btn-add-review-luxury d-inline-flex align-items-center justify-content-center" style="gap: 8px;"
         onclick="event.preventDefault(); handleLoginAction('{{ url_for('add_product_review', slug=product.id) }}'); return false;">
         <span>{% if session.lang == 'ar' %}إضافة تقييم{% else %}Add Review{% endif %}</span>
         <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
           <circle cx="12" cy="12" r="10"></circle>
           <line x1="12" y1="8" x2="12" y2="16"></line>
           <line x1="8" y1="12" x2="16" y2="12"></line>
         </svg>
      </a>
    {% else %}
      <a href="{{ url_for('add_product_review', slug=product.slug) }}"
         class="btn-add-review-luxury d-inline-flex align-items-center justify-content-center" style="gap: 8px;" id="add-review-btn">
         <span>{% if session.lang == 'ar' %}إضافة تقييم{% else %}Add Review{% endif %}</span>
         <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
           <circle cx="12" cy="12" r="10"></circle>
           <line x1="12" y1="8" x2="12" y2="16"></line>
           <line x1="8" y1="12" x2="16" y2="12"></line>
         </svg>
      </a>
    {% endif %}
  </div>
</div>

{% if reviews and reviews | length > 0 %}
  <div class="reviews-luxury-list-wrapper">
    {% for review in reviews %}
      <div class="review-luxury-card mb-5">
        <!-- Review Author Details -->
        <div class="review-luxury-author d-flex align-items-center mb-3">
          <div class="review-luxury-avatar-circle d-flex align-items-center justify-content-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </div>
          <span class="review-luxury-author-name">{{ review.customer.name }}</span>
        </div>

        <!-- Rating Stars -->
        <div class="review-luxury-stars mb-3">
          {% set rating = review.rating %}
          {% include 'components/rating-stars.jinja' %}
        </div>

        <!-- Comment Text -->
        <div class="review-luxury-comment-text mb-3">
          {{ review.comment | safe }}
        </div>

        <!-- Review Photo Attachments -->
        {% if review.images %}
          <div class="review-luxury-images d-flex flex-wrap gap-2 mb-4">
            {% for image in review.images %}
              <div class="review-luxury-image-thumb">
                <img src="{{ image.path }}" alt="{% if session.lang == 'ar' %}مرفق التقييم{% else %}Review attachment{% endif %}" class="img-fluid" attr-index="{{ loop.index0 }}">
              </div>
            {% endfor %}
          </div>
        {% endif %}

        <!-- Store Reply -->
        {% if review.reply %}
          <div class="review-luxury-reply-wrapper mt-4">
            <div class="review-luxury-author d-flex align-items-center mb-3">
              <div class="review-luxury-avatar-circle d-flex align-items-center justify-content-center">
                {% if store.logo %}
                  <img src="{{ store.logo }}" alt="{{ store.name }}" class="store-avatar-img">
                {% else %}
                  <span class="store-avatar-text">{{ store.name[:2] | upper }}</span>
                {% endif %}
              </div>
              <span class="review-luxury-author-name">{{ store.name }}</span>
            </div>

            <div class="review-luxury-comment-text mb-3">
              {{ review.reply.text | safe }}
            </div>

            {% if review.reply.images %}
              <div class="review-luxury-images d-flex flex-wrap gap-2">
                {% for image in review.reply.images %}
                  <div class="review-luxury-image-thumb">
                    <img src="{{ image.path }}" alt="{% if session.lang == 'ar' %}مرفق الرد{% else %}Reply attachment{% endif %}" class="img-fluid" attr-index="{{ loop.index0 }}">
                  </div>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
{% else %}
  <!-- Empty State: No Reviews -->
  <div class="reviews-luxury-empty-wrapper">
    <div class="reviews-luxury-empty">
      <div class="image-box">
        <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Paper Document -->
          <rect x="14" y="10" width="36" height="44" rx="2" stroke="black" stroke-width="2" fill="none"/>
          <!-- Document lines -->
          <line x1="20" y1="22" x2="32" y2="22" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <line x1="20" y1="30" x2="44" y2="30" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <line x1="20" y1="38" x2="44" y2="38" stroke="black" stroke-width="2" stroke-linecap="round"/>
          <!-- Star box at top-right -->
          <rect x="36" y="6" width="16" height="16" rx="1" fill="black"/>
          <!-- White star icon inside the box -->
          <path d="M44 9.5l0.8 1.6 1.8 0.3-1.3 1.2 0.3 1.8-1.6-0.8-1.6 0.8 0.3-1.8-1.3-1.2 1.8-0.3z" fill="white"/>
        </svg>
      </div>
      <p class="empty-title m-0">{% if session.lang == 'ar' %}لا توجد تقييمات سابقة{% else %}There are no previous reviews{% endif %}</p>
      <p class="empty-desc m-0">{% if session.lang == 'ar' %}يمكنك إضافة تقييمك لمشاركة تجربتك{% else %}You can add your review to share your experience{% endif %}</p>
    </div>
  </div>
{% endif %}

<script>
    function timeAgo(dateString) {
        const date = new Date(dateString);
        const now = new Date();
        const seconds = Math.floor((now - date) / 1000);
        let yearAgo = '{{ _("year %s ago") }}';
        let monthAgo = '{{ _("month %s ago") }}';
        let dayAgo = '{{ _("day %s ago") }}';
        let hourAgo = '{{ _("hour %s ago") }}';
        let minuteAgo = '{{ _("minute %s ago") }}';
        let lang = "{{ session.lang }}";
        let interval = Math.floor(seconds / 31536000);

        if (interval >= 1) {
            if (lang === "ar") {
                yearAgo = yearAgo.replace('%s', interval);
                return (interval === 1 ? " {{ _('year ago') }}" : yearAgo);
            }
            return interval + " " + (interval === 1 ? " {{ _('year ago') }}" : " {{ _('year ago') }}");
        }

        interval = Math.floor(seconds / 2592000);
        if (interval >= 1) {
            if (lang === "ar") {
                monthAgo = monthAgo.replace('%s', interval);
                return (interval === 1 ? " {{ _('month ago') }}" : monthAgo);
            }
            return interval + " " + (interval === 1 ? "{{ _('month ago') }}" : "{{ _('months ago') }}");
        }

        interval = Math.floor(seconds / 86400);
        if (interval >= 1) {
            if (lang === "ar") {
                dayAgo = dayAgo.replace('%s', interval);
                return (interval === 1 ? " {{ _('day ago') }}" : dayAgo);
            }
            return interval + " " + (interval === 1 ? " {{ _('day ago') }}" : " {{ _('days ago') }}");
        }

        interval = Math.floor(seconds / 3600);
        if (interval >= 1) {
            if (lang === "ar") {
                hourAgo = hourAgo.replace('%s', interval);
                return (interval === 1 ? " {{ _('hour ago') }}" : hourAgo);
            }
            return interval + " " + (interval === 1 ? "{{ _('hour ago') }}" : " {{ _('hours ago') }}");
        }

        interval = Math.floor(seconds / 60);
        if (interval >= 1) {
            if (lang === "ar") {
                minuteAgo = minuteAgo.replace('%s', interval);
                return (interval === 1 ? " {{ _('minute ago') }}" : minuteAgo);
            }
            return interval + " " + (interval === 1 ? " {{ _('minute ago') }}" : " {{ _('minutes ago') }}");
        }

        return "{{ _('Just now') }}";
    }

document.addEventListener('DOMContentLoaded', function() {
    // Review images click handler - open in lightbox
    document.addEventListener('click', function(e) {
        var img = e.target.closest('.review-luxury-image-thumb img');
        if (!img) return;

        var container = img.parentElement.parentElement;
        var index = parseInt(img.getAttribute('attr-index')) || 0;
        var images = [];

        container.querySelectorAll('img').forEach(function(imgEl) {
            images.push(imgEl.getAttribute('src'));
        });

        if (typeof openPhotoSwiper === 'function') {
            openPhotoSwiper(images, index);
        }
    });
});
</script>
