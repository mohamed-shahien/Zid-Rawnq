                            d="M2 5.85714V17.2857C2 18.0435 2.30102 18.7702 2.83684 19.306C3.37266 19.8418 4.09938 20.1429 4.85714 20.1429H19.1429C19.9006 20.1429 20.6273 19.8418 21.1632 19.306C21.699 18.7702 22 18.0435 22 17.2857V5.85714C22 5.09938 21.699 4.37266 21.1632 3.83684C20.6273 3.30102 19.9006 3 19.1429 3H4.85714C4.09938 3 3.37266 3.30102 2.83684 3.83684C2.30102 4.37266 2 5.09938 2 5.85714Z"
                            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M4.85815 7.28564L12.001 11.5714L19.1439 7.28564" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
                {% endif %}

                {% if website %}
                <a href="{{ website }}" class="footer-social-link footer-theme-text-for-primary-bg mx-2" target="_blank"
                    rel="noopener" aria-label="{{ website }}">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path
                            d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                            stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M7.99998 3H8.99998C7.04998 8.84 7.04998 15.16 8.99998 21H7.99998" stroke="currentColor"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M15 3C16.95 8.84 16.95 15.16 15 21" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M3 16V15C8.84 16.95 15.16 16.95 21 15V16" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M3 9.0001C8.84 7.0501 15.16 7.0501 21 9.0001" stroke="currentColor" stroke-width="1.5"
                            stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
                {% endif %}
            </div>
        </div>

        <div class="col-6 col-lg order-2 mb-4 mb-lg-0">
            {% if dev or not settings.links_1_hide %}
            <h2 class="footer-heading mb-3">
                {% if settings.links_1_title %}
                {{ settings.links_1_title }}
                {% else %}
                {{ _("Store pages") }}
                {% endif %}
            </h2>
            <ul class="footer-links-list list-unstyled mb-0">
                {% for link in store_links %}
                {% if link and link.url and link.title %}
                <li class="mb-3">
                    <a href="{{ link.url }}" class="footer-theme-text-for-primary-bg">
                        {{ link.title }}
                    </a>
                </li>
                {% endif %}
                {% endfor %}
            </ul>
            {% endif %}
        </div>

        <div class="col-6 col-lg order-3 mb-4 mb-lg-0">
            {% if dev or not settings.links_2_hide %}
            <h2 class="footer-heading mb-3">
                {% if settings.links_2_title %}
                {{ settings.links_2_title }}
                {% else %}
                {{ _("Category pages") }}
                {% endif %}
            </h2>
            <ul class="footer-links-list list-unstyled mb-0">
                {% for link in category_links %}
                {% if link and link.url and link.title %}
                <li class="mb-3">
                    <a href="{{ link.url }}" class="footer-theme-text-for-primary-bg">
                        {{ link.title }}
                    </a>
                </li>
                {% endif %}
                {% endfor %}
            </ul>
            {% endif %}
        </div>

        <div class="footer-about-column col-12 col-lg order-4">
            <h2 class="footer-heading mb-3">
                {% if settings.about_us_title %}
                {{ settings.about_us_title }}
                {% else %}
                {{ _("About us") }}
                {% endif %}
            </h2>
            {% if about_description %}
            <div class="footer-body-text footer-about-description">
                {% set plain_about_description = about_description
                | replace("<br>", "\n")
                | replace("<br />", "\n")
                | replace("<br />", "\n")
                | replace("</p>", "\n")
                | striptags
                %}
                {% for line in plain_about_description.split("\n") %}
                {% set line_text = line | trim %}
                {% if line_text %}
                <p class="mb-3">
                    {% for word in line_text.split() %}
                    {% set digit = namespace(found=false) %}
                    {% for character in word %}
                    {% if character in "0123456789٠١٢٣٤٥٦٧٨٩۰۱۲۳۴۵۶۷۸۹" %}
                    {% set digit.found = true %}
                    {% endif %}
                    {% endfor %}
                    {% if digit.found %}
                    <strong class="footer-number-token">{{ word }}</strong>
                    {% else %}
                    {{ word }}
                    {% endif %}
                    {% if not loop.last %} {% endif %}
                    {% endfor %}
                </p>
                {% endif %}
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

    <div class="row footer-secondary-row align-items-center">
        <div class="col-12 col-lg-4 order-2 order-lg-1 text-center mb-4 mb-lg-0">
            <div
                class="footer-payment-methods d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
                {% for payment_method in payment_methods %}
                <a href="/shipping-and-payment" class="footer-payment-method footer-theme-text-for-primary-bg mx-2 my-2"
                    aria-label="{{ payment_method.name }}">
                    <img class="footer-payment-method-image" src="{{ image_url(payment_method.icon, h=80, q=100) }}"
                        alt="{{ payment_method.name }}" height="24" loading="lazy">
                </a>
                {% endfor %}
                {% if dev and not payment_methods %}
                {% set dev_payment_methods = [
                {"name": "Visa", "image": "visa.svg"},
                {"name": "Mastercard", "image": "mastercard.svg"},
                {"name": "Mada", "image": "mada.svg"},
                {"name": "Apple Pay", "image": "apple-pay.svg"}
                ] %}
                {% for payment_method in dev_payment_methods %}
                <a href="/shipping-and-payment" class="footer-payment-method footer-theme-text-for-primary-bg mx-2 my-2"
                    aria-label="{{ payment_method.name }}">
                    <img class="footer-payment-method-image" src="{{ payment_method.image | asset_url }}"
                        alt="{{ payment_method.name }}" height="24" loading="lazy">
                </a>
                {% endfor %}
                {% endif %}
            </div>
        </div>

        <div class="footer-copyright col-12 col-lg-4 order-3 order-lg-2 text-center">
            {{ copyrights | safe }}
        </div>

        <div class="col-12 col-lg-4 order-1 order-lg-3 mb-4 mb-lg-0">
            <div
                class="footer-certificates d-flex flex-wrap align-items-center justify-content-center justify-content-lg-end">
                {% if certificate_visible or tax_number %}
                <a {% if certificate_url %} href="{{ certificate_url }}" target="_blank" rel="noopener" {% endif %}
                    class="footer-certificate-item footer-theme-text-for-primary-bg d-inline-flex align-items-center mx-2 my-2"
                    aria-label="{{ _(" VAT certificate") }}">
                    <img class="flex-shrink-0" src="{{ 'vat-certificate.png' | asset_url }}" alt="{{ _(" VAT
                        certificate") }}" height="40" loading="lazy">
                    <span class="footer-certificate-text mx-2">
                        {% if tax_number %}
                        <span class="d-block">{{ _("The VAT number:") }}
                            <br>{{ tax_number }}</span>
                        {% endif %}
                    </span>
                </a>
                {% endif %}

                {% if business_center or commercial_registration_number %}
                <a {% if business_center %}
                    href="https://eauthenticate.saudibusiness.gov.sa/certificate-details/{{ business_center }}"
                    target="_blank" rel="noopener" {% endif %}
                    class="footer-certificate-item footer-theme-text-for-primary-bg d-inline-flex align-items-center mx-2 my-2">
                    <img class="flex-shrink-0" src="{{ 'business_center.png' | asset_url }}" alt="{{ _(" Business
                        certificate") }}" height="30" loading="lazy">
                    <span class="footer-certificate-text mx-2">

                        {% if commercial_registration_number %}
                        <span class="d-block">
                            {{ _("The commercial register number:") }}
                            <br>{{ commercial_registration_number }}
                        </span>
                        {% endif %}
                    </span>
                </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>