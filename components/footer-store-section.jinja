{% set footer_logo = settings.store_identity_logo if settings.store_identity_logo else store.logo %}
{% set footer_description = settings.store_identity_description if settings.store_identity_description else
store.description %}
{% set store_links = safeget(settings, "links_1_links", []) %}
{% set category_links = safeget(settings, "links_2_links", []) %}
{% set about_description = safeget(settings, "about_us_des", "") %}
{% set facebook = safeget(store, "settings.contact.facebook", "") %}
{% set instagram = safeget(store, "settings.contact.instagram", "") %}
{% set twitter = safeget(store, "settings.contact.twitter", "") %}
{% set snapchat = safeget(store, "settings.contact.snapchat", "") %}
{% set tiktok = safeget(store, "settings.contact.tiktok", "") %}
{% set phone = safeget(store, "settings.contact.phone", "") %}
{% set email = safeget(store, "settings.contact.email", "") %}
{% set whatsapp = safeget(store, "settings.contact.whatsapp", "") %}
{% set website = safeget(store, "settings.contact.website", "") %}
{% set payment_methods = safeget(store, "settings.checkout.payment_methods", []) %}
{% set copyrights = safeget(store, "settings.branding.copyrights", "") %}
{% set footer_logo_is_asset = false %}
{% set dev = true %}

{% if dev %}
{% if not footer_logo %}
{% set footer_logo = "zid-logo.svg" | asset_url %}
{% set footer_logo_is_asset = true %}
{% endif %}
{% set footer_description = footer_description or "متجر إلكتروني يقدم منتجات مختارة بعناية وتجربة شراء موثوقة." %}
{% set store_links = store_links or [
{"title": "من نحن", "url": "/page/about-us"},
{"title": "الأسئلة الشائعة", "url": "/faqs"}
] %}
{% set category_links = category_links or [
{"title": "المنتجات", "url": "/products"},
{"title": "التصنيفات", "url": "/categories"}
] %}
{% set about_description = about_description or "للتواصل عبر واتساب على الرقم +966550304412. خدمة العملاء متاحة من 8
صباحًا حتى 4 مساءً." %}
{% set facebook = facebook or "zid.sa" %}
{% set instagram = instagram or "zid.sa" %}
{% set twitter = twitter or "zidapp" %}
{% set snapchat = snapchat or "zidapp" %}
{% set tiktok = tiktok or "zidapp" %}
{% set phone = phone or "+966550304412" %}
{% set email = email or "hello@example.com" %}
{% set whatsapp = whatsapp or "+966550304412" %}
{% set website = website or "/" %}
{% set copyrights = copyrights or "جميع الحقوق محفوظة للمتجر" %}
{% set certificate_visible = true %}
{% set certificate_url = "#" %}
{% set business_center = "1234567890" %}
{% set tax_number = "310000000000003" %}
{% set commercial_registration_number = "1010123456" %}
{% else %}
{% set certificate_visible = safeget(store, "settings.general.tax_settings.is_certificate_visible", false) %}
{% set certificate_url = safeget(store, "settings.general.tax_settings.tax_registration_certificate", "") %}
{% set business_center = safeget(store, "settings.contact.business_center", "") %}
{% set tax_number = safeget(store, "settings.general.tax_settings.tax_number", "") %}
{% set commercial_registration_number = safeget(store, "settings.general.commercial_registration_number", "") %}
{% endif %}

<div class="footer-content">
    <div class="row footer-primary-row">
        <div class="col-12 col-footer order-1 mb-4 mb-lg-0">
            {% if footer_logo %}
            <a href="/" class="d-inline-block footer-theme-text-for-primary-bg mb-3">
                <img class="footer-logo"
                    src="{% if footer_logo_is_asset %}{{ footer_logo }}{% else %}{{ image_url(footer_logo, h=175, q=100) }}{% endif %}"
                    alt="{{ store.name }}" height="70" loading="lazy">
            </a>
            {% endif %}
            {% if footer_description %}
            <div class="footer-body-text footer-store-description mb-4">
                {{ footer_description | safe }}
            </div>
            {% endif %}

            <h2 class="footer-heading mb-3">
                {% if settings.social_media_title %}
                {{ settings.social_media_title }}
                {% else %}
                {{ _("Contact us") }}
                {% endif %}
            </h2>

            <div class="footer-social-links d-flex flex-wrap align-items-center">
                {% if facebook %}
                <a href="https://www.facebook.com/{{ facebook }}"
                    class="footer-social-link footer-theme-text-for-primary-bg mx-2" target="_blank" rel="noopener"
                    aria-label="Facebook">

