{#
  Products Carousel Component

  Props:
  - products: array of Product objects
  - title: string (optional) - section title
  - more_url: string (optional) - URL for "View all" link
  - more_text: string (optional) - text for "View all" link
  - carousel_id: string (optional) - unique ID for the carousel
  - slides_mobile: number (optional, default 1) - slides shown below 768px
  - slides_tablet: number (optional, default 2) - slides shown between 768px and 991px
  - slides_desktop: number (optional, default 3) - slides shown at 992px and above
#}

{% set carousel_id = carousel_id or 'product-slider-' ~ range(1000, 9999) | random %}
{% set slides_mobile = slides_mobile if slides_mobile is defined else 1 %}
{% set slides_tablet = slides_tablet if slides_tablet is defined else 2 %}
{% set slides_desktop = slides_desktop if slides_desktop is defined else 3 %}

{% if products and products | length > 0 %}
  <section class="mt-5 mb-5">
    <div class="d-flex align-items-center mb-4">
      {% if title %}
      <div class="product-slider-icon" style="font-size: 24px; height: 24px">
        <span class="icon-uniE011"></span>
      </div>
      <div class="product-slider-title">
        <div class="">{{ title }}</div>
      </div>
    </div>
    {% endif %}
    <div class="product-slider-paragrah">
      <div class="">
        <div class="products-slider-wrapper theme-swiper-shell" data-swiper-shell>

          <div id="{{ carousel_id }}" class="products-slider swiper loading d-block">
            <div class="swiper-wrapper">
            {% for rProduct in products %}
              <div class="prod-col swiper-slide">
                {% set product=rProduct %}{% set index=loop.index0 %}
                {% include 'components/product-card.jinja' %}
              </div>
            {% endfor %}
            </div>
          </div>
          <button class="theme-swiper-button-prev theme-swiper-navigation-desktop swiper-button-prev" type="button"></button>
          <button class="theme-swiper-button-next theme-swiper-navigation-desktop swiper-button-next" type="button"></button>

        </div>
      </div>
    </div>
  </section>
  <script>
    window.addEventListener("load", function () {
      var slider = document.getElementById('{{ carousel_id }}');

      if (!slider) {
        return;
      }

      if (!window.themeSwiper) {
        slider.classList.remove('loading');
        return;
      }

      window.themeSwiper.init(slider, {
        slidesPerView: {{ slides_mobile }},
        slidesPerGroup: 1,
        loop: false,
        navigation: true,
        pagination: false,
        breakpoints: {
          768: {
            slidesPerView: {{ slides_tablet }}
          },
          992: {
            slidesPerView: {{ slides_desktop }}
          }
        }
      });
      slider.classList.remove('loading');
    });
  </script>
{% endif %}
