<section id="{{ sectionId }}" section-id="{{ sectionId }}"
         data-lg-scroll-offset="130"
         data-md-scroll-offset="130"
         data-sm-scroll-offset="94">
    <div class="container section-slider-padding-space slider-container">
        <h2 class="section-title theme-text-primary">{{ settings.title }}</h2>

        <div class="testimonials-slider-wrapper theme-swiper-shell" data-swiper-shell>


            <div class="testimonials-slider swiper theme-swiper-desktop-only">
                <div class="swiper-wrapper">

                {% for testimonial in safeget(settings, "testimonials", []) %}

                <div class="testimonials-customer-card bg-transparent swiper-slide">
                    <div class="card-body">
                        <div class="d-flex">
                            <span class="icon-account_circle_black_24dp testimonials-customer-icon"></span>
                            <h2 class="testimonials-customer-name">{{ testimonial.name }}</h2>
                            <p class="testimonials-customer-date">{{ testimonial.date }}</p>
                        </div>
                        <p class="testimonials-customer-text">{{ testimonial.text }}</p>
                    </div>
                </div>

                {% endfor %}

                </div>
            </div>
            <button class="theme-swiper-button-prev swiper-button-prev" type="button"></button>
            <button class="theme-swiper-button-next swiper-button-next" type="button"></button>
            {% if not settings.hide_dots and (safeget(settings, "testimonials", []) | length > 3) %}
                <div class="theme-swiper-pagination swiper-pagination"></div>
            {% endif %}

        </div>

    </div>
</section>


<script>

    document.addEventListener("DOMContentLoaded", function(){
        var section = document.getElementById('{{ sectionId }}');
        var slider = section ? section.querySelector('.testimonials-slider') : null;

        if (slider && window.themeSwiper) {
            window.themeSwiper.initResponsive(slider, {
                slidesPerView: 3,
                slidesPerGroup: 3,
                loop: false,
                autoplay: false,
                navigation: true,
                pagination: {% if (settings.hide_dots or (safeget(settings, "testimonials", []) | length <= 3)) %}false{% else %}true{% endif %}
            }, {
                minWidth: 768
            });
        }
    });
</script>


