<section id="{{ sectionId }}" section-id="{{ sectionId }}"
         data-lg-scroll-offset="130"
         data-md-scroll-offset="130"
         data-sm-scroll-offset="94">
  <div class="container section-slider-padding-space slider-container">

    <h2 class="section-title theme-text-primary">{{ settings.title }}</h2>

    <div class="partners-slider-wrapper theme-swiper-shell" data-swiper-shell>

      <div class="partners-slider swiper theme-swiper-desktop-only">
        <div class="swiper-wrapper">
          {% for store_partner in safeget(settings, "store_partners", []) %}
              <div class="partners-item swiper-slide">
                  {% if store_partner.url %}
                      <a href="{{ store_partner.url }}" style="width: 100%; height: 100%; display: block">
                      {% endif %}
                      <img src="{{ image_url(store_partner.image, w=250, q=100, f='auto') }}" loading="lazy" alt=""
                           style="max-width: 90px; max-height: 90px"/>
                  {% if store_partner.url %}
                      </a>
                  {% endif %}
              </div>
          {% endfor %}
        </div>
      </div>
      <button class="theme-swiper-button-prev swiper-button-prev" type="button"></button>
      <button class="theme-swiper-button-next swiper-button-next" type="button"></button>

    </div>

  </div>

</section>


<script>

    document.addEventListener("DOMContentLoaded", function(){
        var section = document.getElementById('{{ sectionId }}');
        var slider = section ? section.querySelector('.partners-slider') : null;

        if (slider && window.themeSwiper) {
            window.themeSwiper.initResponsive(slider, {
                slidesPerView: 5,
                slidesPerGroup: 5,
                loop: false,
                autoplay: false,
                navigation: true,
                pagination: false
            }, {
                minWidth: 768
            });
        }
    });
</script>
