<div id="{{ sectionId }}" section-id="{{ sectionId }}"
     data-lg-scroll-offset="130"
     data-md-scroll-offset="130"
     data-sm-scroll-offset="94"
     class="home-cards-section section-padding-space">
    <div class="container slider-container">
        <h2 class="section-title theme-text-primary">{{ settings.title }}</h2>
        <div class="d-flex flex-column">
            <div class="cards-slider-wrapper theme-swiper-shell" data-swiper-shell>

                <div class="cards-slider swiper theme-swiper-desktop-only">
                    <div class="swiper-wrapper">
                    {% for card in safeget(settings, "slider", []) %}
                        <div class="card-col swiper-slide">
                            <div class="card-item">
                                <a href="{{ card.url }}">
                                    <img
                                            {% if card.image %}
                                                src="{{ image_url(card.image, w=400, q=100, f='auto') }}"
                                            {% else %}
                                                src="{{ image_url(('product-img.svg' | asset_url), w=235, q=100, f='auto') }}"
                                            {% endif %}

                                            loading="lazy" alt="{{ card.title }}">
                                    <h3>{{ card.title }}</h3>
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                    </div>
                </div>
                <button class="theme-swiper-button-prev swiper-button-prev" type="button"></button>
                <button class="theme-swiper-button-next swiper-button-next" type="button"></button>

            </div>
        </div>
    </div>
</div>

<script>

    document.addEventListener("DOMContentLoaded", function(){
        var section = document.getElementById('{{ sectionId }}');
        var slider = section ? section.querySelector('.cards-slider') : null;

        if (slider && window.themeSwiper) {
            window.themeSwiper.initResponsive(slider, {
                slidesPerView: 5,
                slidesPerGroup: 5,
                loop: false,
                autoplay: false,
                navigation: true,
                pagination: false
            }, {
                minWidth: 768
            });
        }
    });
</script>
