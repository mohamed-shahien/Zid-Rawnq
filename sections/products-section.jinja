<div id="{{ sectionId }}" section-id="{{ sectionId }}"
     data-lg-scroll-offset="130"
     data-md-scroll-offset="130"
     data-sm-scroll-offset="94"
     class="home-products-section section-padding-space">
    <div class="container slider-container">
        <h2 class="section-title theme-title-primary" >{{ settings.title }}</h2>
        <div class="d-flex flex-column">

            <div class="products-slider-wrapper theme-swiper-shell" data-swiper-shell>
                    <div class="products-slider swiper theme-swiper-desktop-only">
                        <div class="swiper-wrapper">
                        {% for product in safeget(settings, "products.results", []) %}
                            <div class="prod-col swiper-slide">
                                {% set index=loop.index0 %}{% include 'components/product-card.jinja' %}
                            </div>
                        {% endfor %}
                        </div>
                    </div>
                <button class="theme-swiper-button-prev swiper-button-prev" type="button"></button>
                <button class="theme-swiper-button-next swiper-button-next" type="button"></button>


                {% if settings.more_text %}
                    <div class="text-center mt-5 category-products-display-more-section">
                        <a href="{{ safeget(settings, "products.url") or url_for('list_products') }}"
                           class="more-button btn btn-outline-primary theme-text-primary theme-border-primary">{{ settings.more_text }}</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

    <script>

        document.addEventListener("DOMContentLoaded", function(){
            var section = document.getElementById('{{ sectionId }}');
            var slider = section ? section.querySelector('.products-slider') : null;

            if (slider && window.themeSwiper) {
                window.themeSwiper.initResponsive(slider, {
                    slidesPerView: 5,
                    slidesPerGroup: 5,
                    loop: false,
                    autoplay: false,
                    navigation: true,
                    pagination: false
                }, {
                    minWidth: 768
                });
            }
        });
    </script>
