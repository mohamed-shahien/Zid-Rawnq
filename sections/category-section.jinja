<div id="{{ sectionId }}" section-id="{{ sectionId }}"
     data-lg-scroll-offset="130"
     data-md-scroll-offset="130"
     data-sm-scroll-offset="94"
     class="home-categories-section section-padding-space">
    <div class="container slider-container">
        <h2 class="section-title theme-text-primary">{{ settings.title }}</h2>
        <div class="d-flex flex-column">
            <div class="categories-slider-wrapper theme-swiper-shell" data-swiper-shell>

                <div class="categories-slider swiper theme-swiper-desktop-only">
                    <div class="swiper-wrapper">
                    {% for categoryItem in safeget(settings, "categories", []) %}
                        <div class="cat-col swiper-slide">
                            <div class="category-item">
                                <a href="/categories/{{ categoryItem.category.id }}/{{ categoryItem.category.slug }}">

                                    <img
                                            {% if categoryItem.category.image %}
                                                src="{{ image_url(categoryItem.category.image_full_size, w=400, q=100, f='auto') }}"
                                            {% else %}
                                                src="{{ image_url(('product-img.svg' | asset_url), w=235, q=100, f='auto') }}"
                                            {% endif %}

                                            loading="lazy" alt="{{ categoryItem.category.name }}">
                                    <h3>{{ categoryItem.category.name }}</h3>
                                </a>
                            </div>
                        </div>
                    {% endfor %}
                    </div>
                </div>
                <button class="theme-swiper-button-prev swiper-button-prev" type="button"></button>
                <button class="theme-swiper-button-next swiper-button-next" type="button"></button>

            </div>

            {% if settings.display_more %}
                <div class="text-center mt-5 category-display-more-section">
                    <a href="{{ url_for('list_categories') }}" class="more-button btn btn-outline-primary theme-text-primary theme-border-primary">{{ settings.more_text }}</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>

    document.addEventListener("DOMContentLoaded", function(){
        var section = document.getElementById('{{ sectionId }}');
        var slider = section ? section.querySelector('.categories-slider') : null;

        if (slider && window.themeSwiper) {
            window.themeSwiper.initResponsive(slider, {
                slidesPerView: 5,
                slidesPerGroup: 5,
                loop: false,
                autoplay: false,
                navigation: true,
                pagination: false
            }, {
                minWidth: 768
            });
        }
    });
</script>
