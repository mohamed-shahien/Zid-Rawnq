<header id="{{ sectionId }}" section-id="{{ sectionId }}" class="simple-header">
    {% include 'vitrin:shared/store_messages.jinja' %}
    <div class="container h-100">
        <div class="d-flex align-items-center justify-content-between h-100">
            <!-- Logo (Left/Right depending on LTR/RTL, flex handles it) -->
            <div class="header-logo" style="flex: 1;">
                <a href="/" style="display: inline-block;">
                    {% if settings.header_logo %}
                        {% set logoUrl = settings.header_logo %}
                    {% else %}
                        {% set logoUrl = store.logo %}
                    {% endif %}
                    <img src="{{ image_url(logoUrl, h=175, q=100) }}" alt="{{ store.name }}" style="max-height: 36px; width: auto;" decoding="async" fetchpriority="high">
                </a>
            </div>

            <!-- Navigation Menu (Middle) -->
            <div class="header-nav d-none d-lg-flex justify-content-center" style="flex: 2; gap: 32px;">
                {% set max_items = 4 %}
                {% for menu in store.settings.menus.main_menu.items %}
                    {% if loop.index0 < max_items %}
                        <a href="{{ menu.url }}" class="nav-link text-uppercase" style="color: #333; font-weight: 500; font-size: 13px; text-decoration: none; letter-spacing: 0.5px;">
                            {{ menu.label }}
                        </a>
                    {% endif %}
                {% endfor %}
                
                {% if store.settings.menus.main_menu.items | length > max_items %}
                    <button class="nav-link btn-more-menu text-uppercase" style="color: #333; font-weight: 500; font-size: 13px; text-decoration: none; letter-spacing: 0.5px; border: none; background: transparent; cursor: pointer; padding: 0;" onclick="toggleMoreMenu()">
                        {{ _("More") }}
                    </button>
                {% endif %}
            </div>

            <!-- Icons (Right) -->
            <div class="header-icons d-flex justify-content-end align-items-center" style="flex: 1; gap: 20px; color: #333;">
                
                <!-- Search -->
                <button class="icon-btn search-btn" onclick="openSearch()" aria-label="Search" style="border: none; background: transparent; cursor: pointer; padding: 0; color: inherit;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </button>

                <!-- User Account -->
                <button class="icon-btn account-btn" onclick="handleLoginAction()" aria-label="Account" style="border: none; background: transparent; cursor: pointer; padding: 0; color: inherit;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                </button>

                <!-- Language / Region -->
                {% set multiple_languages = store.languages | length > 1 %}
                {% if multiple_languages %}
                <button class="icon-btn lang-btn" onclick="zidOpenRegionSettingDialog()" aria-label="Language" style="border: none; background: transparent; cursor: pointer; padding: 0; color: inherit;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
                </button>
                {% endif %}

                <!-- Cart -->
                <a href="/cart" class="icon-btn cart-btn" aria-label="Cart" style="position: relative; color: inherit; text-decoration: none; padding: 0;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
                    <span class="cart-badge d-none" style="position: absolute; top: -6px; right: -8px; background: #333; color: #fff; font-size: 10px; border-radius: 50%; min-width: 16px; height: 16px; display: flex; align-items: center; justify-content: center; font-weight: 600;"></span>
                </a>

                <!-- Mobile Menu Toggle -->
                <button class="icon-btn d-lg-none" onclick="toggleMobileMenu()" aria-label="Menu" style="border: none; background: transparent; cursor: pointer; padding: 0; color: inherit; margin-inline-start: 4px;">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                </button>
            </div>
        </div>
    </div>

    <!-- More Menu Panel (Qima style offcanvas) -->
    <div id="more-menu-panel" class="offcanvas-menu" style="display: none; position: fixed; top: 0; right: 0; bottom: 0; width: 350px; max-width: 100vw; background: #fff; z-index: 1050; box-shadow: -5px 0 15px rgba(0,0,0,0.05); transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);">
        <div class="offcanvas-header d-flex justify-content-between align-items-center" style="padding: 24px; border-bottom: 1px solid #f5f5f5;">
            <h5 class="m-0 text-uppercase" style="font-weight: 500; font-size: 14px; letter-spacing: 0.5px; color: #333;">{{ _("Menu") }}</h5>
            <button onclick="toggleMoreMenu()" style="border: none; background: transparent; cursor: pointer; color: #333; padding: 0;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        <div class="offcanvas-body" style="padding: 24px; overflow-y: auto; height: calc(100% - 73px);">
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 20px;">
                {% for menu in store.settings.menus.main_menu.items %}
                    <li style="border-bottom: 1px solid #f9f9f9; padding-bottom: 12px;">
                        <a href="{{ menu.url }}" style="color: #333; font-size: 15px; font-weight: 500; text-decoration: none; display: block;">{{ menu.label }}</a>
                        {% if menu.items | length > 0 %}
                            <ul style="list-style: none; padding-inline-start: 16px; margin-top: 16px; display: flex; flex-direction: column; gap: 14px;">
                                {% for sub in menu.items %}
                                    <li><a href="{{ sub.url }}" style="color: #666; font-size: 14px; text-decoration: none; display: block;">{{ sub.label }}</a></li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </li>
                {% endfor %}
                <li style="border-bottom: 1px solid #f9f9f9; padding-bottom: 12px;">
                    <a href="/shipping-and-payment" style="color: #333; font-size: 15px; font-weight: 500; text-decoration: none; display: block;">{{ _("Payment and delivery options") }}</a>
                </li>
            </ul>
        </div>
    </div>
    <div id="header-overlay" onclick="closeAllPanels()" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1040; opacity: 0; transition: opacity 0.3s ease;"></div>
    
    <!-- Search Overlay -->
    <div id="search-overlay" class="search-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; background: #fff; z-index: 1060; padding: 40px 0; box-shadow: 0 4px 15px rgba(0,0,0,0.05); transform: translateY(-100%); transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);">
        <div class="container">
            <div class="d-flex align-items-center" style="gap: 20px;">
                <div class="autocomplete flex-grow-1" style="position: relative;">
                    <input type="text" data-cat-id="{{ category.id if category is defined else '' }}" class="form-control search-input-input" placeholder="{{ _('Search') }}" style="border: none; border-bottom: 1px solid #333; border-radius: 0; padding: 12px 0; font-size: 20px; box-shadow: none; background: transparent; outline: none;">
                    <div class="autocomplete-items"></div>
                </div>
                <button onclick="closeSearch()" style="border: none; background: transparent; cursor: pointer; color: #333; padding: 0;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>
        </div>
    </div>
</header>

<style>
    .simple-header {
        height: 72px;
        background: #fdfdfd;
        border-bottom: 1px solid #eaeaea;
        position: relative;
        z-index: 1000;
    }
    
    .simple-header .nav-link {
        transition: color 0.2s ease;
    }
    .simple-header .nav-link:hover {
        color: #000;
        opacity: 0.7;
    }
    .simple-header .icon-btn {
        transition: transform 0.2s ease, opacity 0.2s ease;
    }
    .simple-header .icon-btn:hover {
        opacity: 0.7;
        transform: translateY(-1px);
    }
    
    html[dir="rtl"] #more-menu-panel {
        right: auto !important;
        left: 0 !important;
        transform: translateX(-100%) !important;
    }
    html[dir="rtl"] #more-menu-panel.show {
        transform: translateX(0) !important;
    }
    
    #more-menu-panel.show {
        transform: translateX(0) !important;
    }
    
    body.panel-open {
        overflow: hidden;
    }
    
    .search-input-input:focus {
        box-shadow: none !important;
        border-bottom-color: #000 !important;
    }
</style>

<script>
    function toggleMoreMenu() {
        const panel = document.getElementById('more-menu-panel');
        const overlay = document.getElementById('header-overlay');
        const isShowing = panel.classList.contains('show');
        
        if (isShowing) {
            closeAllPanels();
        } else {
            panel.style.display = 'block';
            overlay.style.display = 'block';
            void panel.offsetWidth;
            panel.classList.add('show');
            overlay.style.opacity = '1';
            document.body.classList.add('panel-open');
        }
    }
    
    function toggleMobileMenu() {
        toggleMoreMenu(); 
    }
    
    function openSearch() {
        const search = document.getElementById('search-overlay');
        const overlay = document.getElementById('header-overlay');
        
        search.style.display = 'block';
        overlay.style.display = 'block';
        void search.offsetWidth;
        search.style.transform = 'translateY(0)';
        overlay.style.opacity = '1';
        document.body.classList.add('panel-open');
        
        setTimeout(() => {
            search.querySelector('input').focus();
        }, 350);
    }
    
    function closeSearch() {
        const search = document.getElementById('search-overlay');
        const overlay = document.getElementById('header-overlay');
        
        search.style.transform = 'translateY(-100%)';
        overlay.style.opacity = '0';
        document.body.classList.remove('panel-open');
        
        setTimeout(() => {
            search.style.display = 'none';
            overlay.style.display = 'none';
        }, 350);
    }
    
    function closeAllPanels() {
        const panel = document.getElementById('more-menu-panel');
        const search = document.getElementById('search-overlay');
        const overlay = document.getElementById('header-overlay');
        
        panel.classList.remove('show');
        search.style.transform = 'translateY(-100%)';
        overlay.style.opacity = '0';
        document.body.classList.remove('panel-open');
        
        setTimeout(() => {
            panel.style.display = 'none';
            search.style.display = 'none';
            overlay.style.display = 'none';
        }, 350);
    }
</script>