{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
	<link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}"/>
{% endblock %}

{% block main_content %}

    <section class="breadcrumb-section">
        <nav aria-label="breadcrumb">

            <ol class="breadcrumb">
                <div class="container d-flex flex-wrap">

                    <li class="breadcrumb-item" aria-current="page"><a href="/">{{ _("Home") }}</a></li>

                    {% if category.parent_category.parent_category %}
                        <li class="breadcrumb-item" aria-current="page"><a href="{{ category.parent_category.parent_category.url }}">{{ category.parent_category.parent_category.name }}</a></li>
                    {% endif %}

                    {% if category.parent_category %}
                        <li class="breadcrumb-item" aria-current="page"><a href="{{ category.parent_category.url }}">{{ category.parent_category.name }}</a></li>
                    {% endif %}

                    <li class="breadcrumb-item active " aria-current="page">{{ category.name }}</li>

                </div>

            </ol>

        </nav>
    </section>

    {% set title=category.name %}{% set description=category.description %}{% include 'components/breadcrumb-subTitle-detail.jinja' %}
    

    {% if category.sub_categories | length > 0 %}
        <div class="container pt-2 category-page-slider">
            <div class="home-categories-section section-padding-space">
                <div class="container slider-container">
                    <h2 class="section-title" style="font-weight: normal; font-size: 1.167rem;">{{ _("Categories") }}</h2>
                    <div class="d-flex flex-column">
                        <div class="categories-slider-wrapper theme-swiper-shell" data-swiper-shell>

                            <div class="categories-slider swiper theme-swiper-desktop-only">
                                <div class="swiper-wrapper">
                                {% for categoryItem in category.sub_categories %}
                                    <div class="cat-col swiper-slide">
                                        <div class="category-item">
                                            <a href="/categories/{{ categoryItem.id }}/{{ categoryItem.slug }}">

                                                <img
                                                        {% if categoryItem.image %}
                                                            src="{{ image_url(categoryItem.image, w=235, q=100, f='auto') }}"
                                                        {% else %}
                                                            src="{{ image_url(('product-img.svg' | asset_url) , w=235, q=100, f='auto') }}"
                                                        {% endif %}

                                                        loading="lazy" alt="{{ categoryItem.name }}">
                                                <h3>{{ categoryItem.name }}</h3>
                                            </a>
                                        </div>
                                    </div>
                                {% endfor %}
                                </div>
                            </div>
                            <button class="theme-swiper-button-prev swiper-button-prev" type="button"></button>
                            <button class="theme-swiper-button-next swiper-button-next" type="button"></button>

                        </div>
                    </div>
                </div>
            </div>

            <script>

                document.addEventListener("DOMContentLoaded", function(){
                    var slider = document.querySelector('.category-page-slider .categories-slider');

                    if (slider && window.themeSwiper) {
                        window.themeSwiper.initResponsive(slider, {
                            slidesPerView: 5,
                            slidesPerGroup: 5,
                            loop: false,
                            autoplay: false,
                            navigation: true,
                            pagination: false
                        }, {
                            minWidth: 768
                        });
                    }
                });
            </script>
        </div>
    {% endif %}

    <div class="container d-flex flex-row">
        {% if  products.filters|length > 0 %}
            {% set async=true %} {% include 'vitrin:products/filters.jinja' %}
            
        {% endif %}
        <div class="products-container flex-grow-1 pt-4">
            <div>
                {% set count=products.count %}{% set has_products_filtration=(products.filters|length > 0) %}{% include 'components/products-filter.jinja' %}
            </div>
            <div id="products-list" class="row products-list">
                {% for product in products.results %}

                    <div class="prod-col {% if products.filters|length > 0 %}prod-col-attr{% endif %} prod-col-tb">
                        {% set product=product %}{% set index=key %}{% include 'components/product-card.jinja' %}
                    </div>

                {% endfor %}
            </div>
        </div>
    </div>

    {% set totalPages=products.pages_count %}{% set currentPage=products.page %}{% include 'components/pagination.jinja' %}

    <div class="container">
      {% set entity = category %}
      {% include 'vitrin:shared/metafields.jinja' %}
    </div>

{% endblock %}

{% block footer %} {% include 'footer.jinja' %} {% endblock %}


{% block footer_scripts %}
    <script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}" defer></script>
    <script>
        window.onProductAttributesTriggered = function(){
            $('#products-list').css('opacity', '0.4');
            $('#product-pagination').css('opacity', '0');

        }

        window.onProductAttributesChanged = function(htmlStr){
            var html = $.parseHTML( htmlStr );
            $('#products-list').html($('#products-list', html).html());
            $('#products-list').css('opacity', '1');
            $('#product-filter-count').html($('#product-filter-count', html).html());
            $('#product-filter-count').css('opacity', '1');

            if($('#product-pagination', html).length>0){
                $('#product-pagination').html($('#product-pagination', html).html());
                $('#product-pagination').css('opacity', '1');
            }
        }

    </script>
{% endblock %}
