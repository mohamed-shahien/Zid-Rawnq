{% block footer_scripts %}

<script type="text/javascript" src="{{ ('product-details.js?v=' ~ ver) | asset_url }}" defer></script>
<script>
    var productImages = {{ product.selected_product.media | tojson }};
    var baseProductImages = Array.isArray(productImages) ? productImages.slice() : [];
    var customerWishlistIds = {{ customer.wishlist | tojson if customer else '[]' }};
    var productGallerySwiper = null;
    var productThumbsSwiper = null;
    var baseFormattedPrice = null;
    var baseFormattedOldPrice = null;

    var productVariantsData = {{ product.variants | default ([]) | tojson }};

    function getVariantImageData(variant) {
        var image = variant && variant.image ? variant.image : null;

        if (!image && variant && Array.isArray(variant.images) && variant.images.length > 0) {
            image = variant.images[0].image || variant.images[0];
        }

        if (!image && variant && Array.isArray(variant.media) && variant.media.length > 0) {
            image = variant.media[0].image || variant.media[0];
        }

        if (image && image.image) {
            image = image.image;
        }

        if (!image) {
            return null;
        }

        var galleryUrl = image.full_size || image.large || image.medium || image.url || null;
        var optionUrl = image.medium || image.full_size || image.large || image.url || null;

        if (!galleryUrl || !optionUrl) {
            return null;
        }

        return {
            galleryUrl: galleryUrl,
            optionUrl: optionUrl
        };
    }

    function normalizeVariantOptionValue(value) {
        return String(value || '').replace(/\s+/g, ' ').trim().toLowerCase();
    }

    function normalizeImageUrl(value) {
        if (!value) {
            return '';
        }

        try {
            return new URL(value, window.location.href).pathname.toLowerCase();
        } catch (error) {
            return String(value).split('?')[0].toLowerCase();
        }
    }

    function getImageFileName(value) {
        var normalizedUrl = normalizeImageUrl(value);
        return normalizedUrl.substring(normalizedUrl.lastIndexOf('/') + 1);
    }

    function getProductMediaImage(mediaItem) {
        if (!mediaItem) {
            return null;
        }

        return mediaItem.image || mediaItem;
    }

    function getVariantMediaItems(variant) {
        if (!variant) {
            return [];
        }

        if (Array.isArray(variant.media) && variant.media.length) {
            return variant.media;
        }

        if (Array.isArray(variant.images) && variant.images.length) {
            return variant.images;
        }

        return variant.image ? [variant.image] : [];
    }

    function buildCompleteProductGalleryMedia(extraMedia) {
        var candidates = baseProductImages.slice();

        productVariantsData.forEach(function (variant) {
            candidates = candidates.concat(getVariantMediaItems(variant));
        });

        if (Array.isArray(extraMedia)) {
            candidates = candidates.concat(extraMedia);
        }

        var seen = {};
        return candidates.reduce(function (result, mediaItem) {
            var image = getProductMediaImage(mediaItem);
            var imageUrl = image && (image.full_size || image.large || image.medium || image.url);
            var imageKey = normalizeImageUrl(imageUrl);

            if (!imageKey || seen[imageKey]) {
                return result;
            }

            seen[imageKey] = true;
            result.push(mediaItem.image ? mediaItem : { image: mediaItem });
            return result;
        }, []);
    }

    function getProductGalleryMediaSignature(mediaItems) {
        if (!Array.isArray(mediaItems)) {
            return '';
        }

        return mediaItems.map(function (mediaItem) {
            var image = getProductMediaImage(mediaItem) || {};
            return normalizeImageUrl(image.full_size || image.large || image.medium || image.url);
        }).filter(Boolean).join('|');
    }

    function getProductGalleryImageIndex(mediaItems, imageUrl) {
        if (!Array.isArray(mediaItems) || !imageUrl) {
            return -1;
        }

        var targetPath = normalizeImageUrl(imageUrl);
        var targetFileName = getImageFileName(imageUrl);

        return mediaItems.findIndex(function (mediaItem) {
            var image = getProductMediaImage(mediaItem) || {};
            var mediaUrl = image.full_size || image.large || image.medium || image.url;
            var mediaPath = normalizeImageUrl(mediaUrl);

            return mediaPath === targetPath
                || (targetFileName && getImageFileName(mediaPath) === targetFileName);
        });
    }

    function slideProductGalleryToImage(imageUrl, retryCount) {
        if (!imageUrl) {
            return;
        }

        var slides = Array.prototype.slice.call(
            document.querySelectorAll('#product-images-swiper .swiper-slide')
        );
        var targetPath = normalizeImageUrl(imageUrl);
        var targetFileName = getImageFileName(imageUrl);
        var targetIndex = slides.findIndex(function (slide) {
            var slideImage = slide.querySelector('.carousel-img, img');

            if (!slideImage) {
                return false;
            }

            var slidePath = normalizeImageUrl(slideImage.currentSrc || slideImage.src);
            return slidePath === targetPath
                || (targetFileName && getImageFileName(slidePath) === targetFileName);
        });
        var swiperElement = document.getElementById('product-images-swiper');
        var swiperInstance = productGallerySwiper || (swiperElement && swiperElement.swiper);

        if (targetIndex >= 0 && swiperInstance && !swiperInstance.destroyed) {
            if (swiperInstance.activeIndex !== targetIndex) {
                swiperInstance.slideTo(targetIndex);
            } else {
                syncProductGalleryThumbnail(targetIndex);
            }
            return;
        }

        if ((retryCount || 0) < 5) {
            window.setTimeout(function () {
                slideProductGalleryToImage(imageUrl, (retryCount || 0) + 1);
            }, 80);
        }
    }

    function applyVariantOptionImages() {
        var optionsRoot = document.getElementById('product-variants-options');

        if (!optionsRoot || !Array.isArray(productVariantsData)) {
            return;
        }

        var imageCandidatesByOptionValue = {};

        productVariantsData.forEach(function (variant) {
            var imageData = getVariantImageData(variant);

            if (!imageData || !Array.isArray(variant.attributes)) {
                return;
            }

            variant.attributes.forEach(function (attribute) {
                var optionValue = normalizeVariantOptionValue(attribute && attribute.value);

                if (!optionValue) {
                    return;
                }

                if (!imageCandidatesByOptionValue[optionValue]) {
                    imageCandidatesByOptionValue[optionValue] = {};
                }

                imageCandidatesByOptionValue[optionValue][imageData.galleryUrl] = imageData;
            });
        });

        optionsRoot.querySelectorAll('ul li').forEach(function (optionItem) {
            var trigger = optionItem.querySelector('a, label, button, span') || optionItem;
            var rawValue = optionItem.getAttribute('value')
                || trigger.getAttribute('data-value')
                || optionItem.getAttribute('data-value')
                || trigger.textContent;
            var optionValue = normalizeVariantOptionValue(rawValue);
            var imageCandidates = Object.keys(imageCandidatesByOptionValue[optionValue] || {});
            var imageData = imageCandidates.length === 1
                ? imageCandidatesByOptionValue[optionValue][imageCandidates[0]]
                : null;

            if (!imageData) {
                return;
            }

            optionItem.setAttribute('data-variant-image-url', imageData.galleryUrl);

            var optionGroup = optionItem.closest('.form-group');
            if (optionGroup) {
                optionGroup.classList.add('variant-image-options-group');
            }

            var existingImage = trigger.querySelector('img');
            if (existingImage) {
                existingImage.classList.add('variant-option-image');
                existingImage.loading = 'lazy';
                existingImage.decoding = 'async';
                optionItem.classList.add('variant-image-option');
                return;
            }

            var image = document.createElement('img');
            image.className = 'variant-option-image';
            image.src = imageData.optionUrl;
            image.alt = String(rawValue || '').trim();
            image.loading = 'lazy';
            image.decoding = 'async';

            optionItem.classList.add('variant-image-option');
            optionItem.setAttribute('aria-label', image.alt);
            optionItem.setAttribute('title', image.alt);
            trigger.setAttribute('aria-label', image.alt);
            trigger.appendChild(image);
        });

        preparePdpImages(optionsRoot);
    }

    function initProductDescriptionCollapses() {
        try {
            var source = document.querySelector('[data-product-description-source]');
            var intro = document.querySelector('[data-product-description-intro]');
            var introShell = source && source.closest('#product-description');
            var outputShell = document.querySelector('[data-product-description-collapses]');
            var output = outputShell
                && outputShell.querySelector('[data-product-description-collapse-content]');

            if (!source || !intro || !introShell || !outputShell || !output) {
                return;
            }

            var introNodes = [];
            var sections = [];
            var currentSection = null;
            var revealDuration = 820;
            var skeletonVisibleTime = 260;
            var reduceMotion = window.matchMedia
                && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            function revealShell(shell, content, shouldShow) {
                if (!shell) return;
                var skeleton = shell.querySelector('[data-product-description-skeleton]');

                if (reduceMotion) {
                    if (content) content.hidden = !shouldShow;
                    if (skeleton) {
                        skeleton.hidden = true;
                        skeleton.style.setProperty('display', 'none', 'important');
                        skeleton.remove();
                    }
                    shell.hidden = !shouldShow;
                    shell.classList.remove('is-splitting', 'is-resolving', 'is-emptying');
                    shell.classList.add('is-ready');
                    shell.removeAttribute('aria-busy');
                    return;
                }

                var startHeight = Math.max(
                    shell.getBoundingClientRect().height,
                    skeleton ? skeleton.getBoundingClientRect().height : 0,
                    1
                );
                shell.style.height = startHeight + 'px';

                window.setTimeout(function () {
                    if (!shouldShow) {
                        shell.classList.add('is-resolving', 'is-emptying');
                        window.requestAnimationFrame(function () {
                            shell.style.height = '0px';
                        });
                        window.setTimeout(function () {
                            if (skeleton) skeleton.remove();
                            shell.hidden = true;
                            shell.classList.remove('is-splitting', 'is-resolving', 'is-emptying');
                            shell.style.height = '';
                            shell.removeAttribute('aria-busy');
                            shell.style.setProperty('display', 'none', 'important');
                        }, revealDuration);
                        return;
                    }

                    if (content) content.hidden = false;
                    var targetHeight = content ? Math.max(content.scrollHeight, 1) : startHeight;
                    shell.classList.add('is-resolving');
                    window.requestAnimationFrame(function () {
                        shell.style.height = targetHeight + 'px';
                    });

                    window.setTimeout(function () {
                        if (skeleton) {
                            skeleton.hidden = true;
                            skeleton.style.setProperty('display', 'none', 'important');
                            skeleton.remove();
                        }
                        shell.classList.remove('is-splitting', 'is-resolving');
                        shell.classList.add('is-ready');
                        shell.style.height = '';
                        shell.removeAttribute('aria-busy');
                    }, revealDuration);
                }, skeletonVisibleTime);
            }

            function hasContent(nodes) {
                return nodes.some(function (contentNode) {
                    return contentNode.nodeType === 1 || String(contentNode.textContent || '').trim();
                });
            }

            var sourceNodes = Array.prototype.slice.call(source.childNodes).filter(function (node) {
                return node.nodeType === 1 || (node.nodeType === 3 && String(node.textContent || '').trim().length > 0);
            });
            while (sourceNodes.length === 1 && sourceNodes[0].nodeType === 1 && !/^(H1|H2)$/.test(sourceNodes[0].tagName)) {
                sourceNodes = Array.prototype.slice.call(sourceNodes[0].childNodes).filter(function (node) {
                    return node.nodeType === 1 || (node.nodeType === 3 && String(node.textContent || '').trim().length > 0);
                });
            }

            sourceNodes.forEach(function (node) {
                var isHeading = node.nodeType === 1 && /^(H1|H2)$/.test(node.tagName);

                if (isHeading) {
                    if (currentSection && hasContent(currentSection.nodes)) {
                        sections.push(currentSection);
                    }

                    currentSection = {
                        title: String(node.textContent || '').trim(),
                        nodes: []
                    };
                    return;
                }

                if (currentSection) {
                    currentSection.nodes.push(node);
                } else {
                    introNodes.push(node);
                }
            });

            if (currentSection && hasContent(currentSection.nodes)) {
                sections.push(currentSection);
            }

            if (hasContent(introNodes)) {
                introNodes.forEach(function (node) {
                    intro.appendChild(node);
                });
            }

            sections.forEach(function (section) {
                var details = document.createElement('details');
                details.className = 'accordion-minimal product-description-collapse';

                var summary = document.createElement('summary');
                summary.className = 'accordion-minimal-header';
                summary.textContent = section.title;

                var content = document.createElement('div');
                content.className = 'accordion-minimal-content description-text-clear';
                section.nodes.forEach(function (node) {
                    content.appendChild(node);
                });

                details.appendChild(summary);
                details.appendChild(content);
                output.appendChild(details);
            });

            source.hidden = true;
            revealShell(introShell, intro, hasContent(introNodes));
            revealShell(outputShell, output, sections.length > 0);
        } catch (e) {
            console.error("Error in initProductDescriptionCollapses:", e);
        }
    }

