{% extends "layout.jinja" %}
{% set dev = true %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
<link rel="stylesheet" type="text/css" href="{{ ('product-details.css?v=' ~ ver)  | asset_url }}" />

{% endblock %}


{% block main_content %}

{% if product %}
{% set selected_product = selected_product if selected_product is defined else product.selected_product %}
{% set has_preorder = product.effective_preorder_campaign is not none %}
{% set can_preorder = product.can_be_preordered %}
{% set preorder_stock_behavior = product.preorder_stock_behavior %}
{% set can_buy = (selected_product and (selected_product.in_stock or can_preorder)) %}
{% else %}
{% set has_preorder = false %}
{% set can_preorder = false %}
{% set preorder_stock_behavior = '' %}
{% set can_buy = false %}
{% endif %}

<section class="product products-details-page" data-has-preorder="{{ 'true' if has_preorder else 'false' }}"
    data-can-preorder="{{ 'true' if can_preorder else 'false' }}"
    data-stock-behavior="{{ preorder_stock_behavior or '' }}"
    data-mobile-sticky-cart="{{ 'true' if settings.product_page_sticky_add_to_cart else 'false' }}">
    <div class="luxury-product-page pb-5">
        {% if product.categories and product.categories | length > 0 %}
        <div class="breadcrumb-minimal d-flex align-items-center mt-3 container">
            <a href="{{ store.home_url }}" class="text-muted" style="text-decoration: none;">{{ _('Home') }}</a>
            {% for cat in product.categories %}
            <span class="mx-2 text-muted breadcrumb-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 18l6-6-6-6" />
                </svg>
            </span>
            <a href="{{ cat.url }}" class="text-muted" style="text-decoration: none;">{{ cat.name }}</a>
            {% endfor %}
            <span class="mx-2 text-muted breadcrumb-arrow">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 18l6-6-6-6" />
                </svg>
            </span>
            <span class="text-dark font-weight-500">{{ product.name }}</span>
        </div>
        {% endif %}
        <section class="products-details mb-5 container">
            <div>
                <div class="row">

                    <div class="col-lg-6 pdp-gallery-column">

                        <!--GALLERY-->
                        <div id="wrap">
                            <div class="row">
                                <div class="col-12 col-product-image-wrapper">

                                    <!-- Carousel -->
                                    <div
                                        class="box-1-1 product-images-carousel product-images-carousel-init {% if product.selected_product.media | length <= 0 %}d-none{% endif %}">
                                        <div class="content">
                                            <div id="product-images"
                                                class="product-images slide gallery theme-swiper-shell"
                                                data-swiper-shell>
                                                <div id="product-images-swiper" class="swiper">
                                                    <div class="swiper-wrapper">
                                                        {% for image in product.selected_product.media %}
                                                        <div class="swiper-slide">
                                                            <div class="box-1-1">
                                                                <div class="content">
                                                                    <a class="image-link"
                                                                        style="display:block; width: 100%; height: 100%;">
                                                                        <img src="{{ image.image.full_size }}"
                                                                            class="carousel-img"
                                                                            loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
                                                                            decoding="async"
                                                                            fetchpriority="{% if loop.first %}high{% else %}low{% endif %}"
                                                                            alt="{{ image.alt_text }}">
                                                                        {% if image.provider and image.link %}
                                                                        <img id="main-video-icon" class="play-icon"
                                                                            src="{{ 'video-play.svg' | asset_url }}"
                                                                            alt="play" width="25" loading="lazy"
                                                                            decoding="async"
                                                                            onClick="showIframe(this, '{{ image.link }}')" />
                                                                        {% endif %}
                                                                    </a>
                                                                    {% if image.provider and image.link %}
                                                                    <div class="iframe-video pt-1 d-none">
                                                                        <a id="iframe-close-btn" type="button"
                                                                            class="text-white btn btn-none grow"
                                                                            onClick="hideIframe(this)">
                                                                            X
                                                                        </a>
                                                                        <iframe width="100%" height="100%" src=""
                                                                            loading="lazy" frameborder="0"
                                                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                                            allowfullscreen style="max-width: 100%">
                                                                        </iframe>
                                                                    </div>
                                                                    {% endif %}
                                                                </div>
                                                            </div>
                                                        </div>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                                <div
                                                    class="theme-swiper-pagination product-gallery-pagination swiper-pagination">
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div id="product-images-thumbs-swiper"
                                        class="swiper lg-thumbs product-images-carousel-thumbs {% if product.selected_product.media | length <= 1 %}d-none-important{% endif %}">
                                        <div class="swiper-wrapper">
                                            {% for image in product.selected_product.media %}
                                            <div class="swiper-slide">
                                                <div class="box-1-1">
                                                    <div class="content">
                                                        <a class="d-flex align-items-center justify-content-center thumb-image-a"
                                                            data-index="{{ loop.index0 }}"
                                                            style="width: 100%; height: 100%;">
                                                            <img src="{{ image.image.medium }}"
                                                                data-index="{{ loop.index0 }}" loading="lazy"
                                                                decoding="async" alt="{{ image.alt_text }}">
                                                            {% if image.provider and image.link %}
                                                            <img id="video-play-icon" class="play-icon"
                                                                src="{{ 'video-play.svg' | asset_url }}" alt="play"
                                                                data-index="{{ loop.index0 }}" loading="lazy"
                                                                decoding="async" />
                                                            {% endif %}
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                            {% endfor %}
                                        </div>
                                    </div>

                                    <!-- No image -->
                                    <div
                                        class="box-1-1 product-images-empty {% if product.selected_product.media | length > 0 %}d-none{% endif %}">
                                        <div class="content">
                                            <div class="d-flex" style="width: 100%; height: 100%;">
                                                <img src="{{ 'product-img.svg' | asset_url }}" width="100%"
                                                    height="auto" loading="lazy" decoding="async"
                                                    alt="{{ product.name | safe }}" />
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="col-lg-6 col-product-info {% if product.selected_product.media | length <= 1 %}col-product-info-single-image{% endif %}"
                        style="display: flex; flex-direction: column; gap: 16px;">

                        {# 1. Product name and price #}
                        <div class="pdp-title-price-row pdp-order-title d-flex justify-content-between align-items-start"
                            style="gap: 16px;">
                            <div>
                                <h1 class="mb-0" style="font-size: 28px; font-weight: 600; line-height: 1.2;">{{
                                    product.name | safe }}</h1>
                            </div>
                            <div class="pdp-price-row d-flex align-items-center" style="gap: 8px; flex-shrink: 0;">
                                <h2 class="product-formatted-price theme-text-primary m-0"
                                    style="font-size: 28px; font-weight: 600; line-height: 1;">{%
                                    if product.selected_product.formatted_sale_price %}{{
                                    product.selected_product.formatted_sale_price }}{% else %}{{
                                    product.selected_product.formatted_price }}{% endif %}</h2>
                                {% if product.selected_product.formatted_sale_price %}
                                <del class="product-formatted-price-old text-muted m-0"
                                    style="font-size: 20px; font-weight: 600; line-height: 1;">{{
                                    product.selected_product.formatted_price
                                    }}</del>
                                {% endif %}
                            </div>
                        </div>

                        {# 2. Short description #}
                        {% if product.short_description %}
                        <div class="text-short-description pdp-order-short-description text-muted"
                            style="font-size: 14px; font-weight: 300; line-height: 1.6;">
                            {{ product.short_description | safe }}
                        </div>
                        {% endif %}



                        {# 4. Payment widgets #}
                        <div class="payment-widgets-minimal pdp-order-payment pdp-async is-loading" data-pdp-async-slot
                            data-pdp-empty-timeout="1800" style="--pdp-skeleton-height: 64px;">{% include
                            'vitrin:products/payment_widgets.jinja' %}</div>

                        {# 5. Loyalty points #}
                        <div class="loyalty-widget-minimal pdp-order-loyalty pdp-async is-loading" data-loyalty-widget
                            data-pdp-async-slot data-pdp-empty-timeout="1800" style="--pdp-skeleton-height: 90px;">{%
                            include 'vitrin:products/loyalty_points_widget.jinja' %}</div>

                        {# 3. Reviews, Weight, SKU and Stock Quantity Summary #}
                        <div class="product-metadata-summary-container pdp-order-rating"
                            style="display: flex; flex-direction: column; gap: 10px;">
                            <!-- Row 1: Rating Stars (Left) & Weight (Right) -->
                            <div class="d-flex align-items-center justify-content-between" style="gap: 16px;">
                                <div class="product-rating-summary">
                                    {% set rating_val = product.rating.average if (product.rating and
                                    product.rating.average) else (5 if dev else 0) %}
                                    {% if rating_val > 0 or (product.reviews.results | length > 0) %}
                                    {% set rating = rating_val if rating_val > 0 else 5 %}
                                    {% include 'components/rating-stars.jinja' %}
                                    {% set reviews_count = product.rating.total_count if (product.rating and
                                    product.rating.total_count) else (product.reviews.results | length if
                                    (product.reviews and product.reviews.results) else (12 if dev else 0)) %}
                                    <span class="product-card-rating-count ml-2" style="font-size: 14px;">({{
                                        reviews_count }} {% if session.lang == 'ar' %}تقييم{% else %}ratings{% endif
                                        %})</span>
                                    {% endif %}
                                </div>
                                <div class="div-product-weight {% if not product.selected_product.weight.value %}d-none{% endif %}"
                                    style="display: inline-flex; align-items: center; gap: 6px; font-size: 14px;">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                        style="vertical-align: middle;">
                                        <path
                                            d="M6 12h12M6 8a6 6 0 0 1 12 0v4H6V8zm-2 4h16v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-8z" />
                                    </svg>
                                    <span class="product-weight">
                                        {{ product.selected_product.weight.value }}{% if
                                        product.selected_product.weight.value %}&nbsp;{{
                                        product.selected_product.weight.unit }}{% endif %}
                                    </span>
                                </div>
                            </div>

                            <!-- Row 2: SKU (Left) & Available Stock Qty (Right) -->
                            <div class="d-flex align-items-center justify-content-between" style="gap: 16px;">
                                <div class="div-product-sku {% if not product.selected_product.sku %}d-none{% endif %}"
                                    style="display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: var(--text-primary);">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                        style="vertical-align: middle;">
                                        <path
                                            d="M3 5v14c0 1.1.9 2 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2z" />
                                        <path d="M7 7v10M10 7v10M13 7v10M17 7v10" />
                                    </svg>
                                    <span class="product-sku">{{ product.selected_product.sku }}</span>
                                </div>
                                <div class="div-product-stock-qty {% if selected_product.is_infinite or not selected_product.quantity %}d-none{% endif %}"
                                    style="font-size: 14px; display: inline-flex; align-items: center; gap: 6px; color: var(--text-secondary);">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                        style="vertical-align: middle;">
                                        <path
                                            d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z">
                                        </path>
                                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                                        <line x1="12" y1="22.08" x2="12" y2="12"></line>
                                    </svg>
                                    <span class="product-stock-qty">
                                        {{ _("Remaining %s only") | replace('%s', selected_product.quantity) }}
                                    </span>
                                </div>
                            </div>
                        </div>
                        {# 6. Product description intro stays open; headed sections move below purchase controls. #}
                        {% if product.description %}
                        <section id="product-description"
                            class="pdp-order-description pdp-description-split-shell is-splitting" aria-busy="true">
                            <div data-product-description-skeleton
                                class="pdp-description-skeleton pdp-description-skeleton--intro" aria-hidden="true">
                                <span class="pdp-description-skeleton-line"></span>
                                <span class="pdp-description-skeleton-line is-medium"></span>
                                <span class="pdp-description-skeleton-line is-short"></span>
                            </div>
                            <div data-product-description-source class="description-text-clear" hidden>
                                {% autoescape false %}
                                {{ product.description }}
                                {% endautoescape %}
                            </div>
                            <div data-product-description-intro
                                class="description-text-clear pdp-description-split-content" hidden></div>
                            <noscript>
                                <style>
                                    #product-description>[data-product-description-skeleton],
                                    [data-product-description-collapses] {
                                        display: none;
                                    }
                                </style>
                                <div class="description-text-clear">
                                    {% autoescape false %}
                                    {{ product.description }}
                                    {% endautoescape %}
                                </div>
                            </noscript>
                        </section>
                        {% endif %}

                        {# 7. Product metadata #}
                        {% if product.metafields %}
                        <section id="product-metafields" class="pdp-order-metafields">
                            {% set entity = product %}
                            {% include 'vitrin:shared/metafields.jinja' %}
                        </section>
                        {% endif %}

                        <form id="product-form" style="display: flex; flex-direction: column; gap: var(--spacing-sm);">
                            <input id="product-id" type="hidden" value="{{ product.selected_product.id }}">

                            {# 8. Product options #}
                            {% if product.has_variants %}
                            <div class="size-box pdp-order-options pdp-hydrate is-loading" data-pdp-hydrate>
                                {% include 'vitrin:products/variants_list.jinja' %}
                            </div>
                            {% endif %}

                            {# 9. Custom input fields #}
                            {% if product.custom_input_fields %}
                            <div class="product-custom-input-fields pdp-order-custom-fields">
                                {% include 'vitrin:products/custom_input_fields.jinja' %}
                            </div>
                            {% endif %}

                            {% if product.product_class == 'dynamic_bundle' %}
                            <div class="pdp-order-bundle">
                                <h4 class="pdp-bundle-title text-uppercase mb-4"
                                    style="font-size: 14px; letter-spacing: 1.5px; font-weight: 600; color: var(--text-primary);">
                                    {{ _("Pairs nicely with") }}</h4>

                                <div class="bundle-swiper-container swiper" style="display: none;">
                                    <div class="swiper-wrapper" id="custom-bundle-wrapper"></div>
                                    <div class="bundle-swiper-scrollbar swiper-scrollbar"></div>
                                </div>

                                <div class="bundle-mui-hidden" aria-hidden="true"
                                    style="opacity: 0; position: absolute; pointer-events: none; width: 0; height: 0; overflow: hidden; z-index: -1;">
                                    {% include 'vitrin:products/bundle-products.jinja' %}
                                </div>
                            </div>

                            <script>
                                (function () {
                                    var ADD_TEXT = '{{ _("ADD TO BAG") }}';
                                    var ADDED_TEXT = 'ADDED ✓';
                                    var swiperInstance = null;

                                    function buildSlider() {
                                        var muiContainer = document.querySelector('.bundle-mui-hidden');
                                        var wrapper = document.getElementById('custom-bundle-wrapper');
                                        var swiperContainer = document.querySelector('.bundle-swiper-container');
                                        if (!muiContainer || !wrapper || !swiperContainer) return;

                                        var items = muiContainer.querySelectorAll('.dynamic-bundle-item');
                                        if (!items.length) return;

                                        wrapper.innerHTML = '';

                                        items.forEach(function (item, index) {
                                            var img = item.querySelector('.dynamic-bundle-item-image img');
                                            var nameEl = item.querySelector('.dynamic-bundle-item-details p');
                                            var checkbox = item.querySelector('input[type="checkbox"]');

                                            if (!img) return;

                                            var optionsContainer = item.querySelector('.dynamic-bundle-item-options, .product-swatches, .variant-options');
                                            var optionsHtml = optionsContainer ? optionsContainer.outerHTML : '';

                                            var priceEl = item.querySelector('.dynamic-bundle-item-price, [class*="price"], [class*="Price"]');
                                            if (!priceEl) {
                                                var allDescendants = item.querySelectorAll('*');
                                                for (var i = 0; i < allDescendants.length; i++) {
                                                    var el = allDescendants[i];
                                                    if (nameEl && el.contains(nameEl)) continue;
                                                    if (el.querySelector('del') || el.textContent.indexOf('SAR') > -1 || el.textContent.indexOf('ر.س') > -1 || el.classList.contains('text-muted')) {
                                                        priceEl = el;
                                                        break;
                                                    }
                                                }
                                            }

                                            var priceHtml = priceEl ? priceEl.innerHTML : '';

                                            var badgeEl = item.querySelector('.discount-badge, [class*="discount"], [class*="badge"]');
                                            if (badgeEl && !priceHtml.includes(badgeEl.textContent)) {
                                                priceHtml += '<span class="discount-badge" style="background: #111; color: #fff; padding: 4px 8px; font-size: 12px; font-weight: 500;">' + badgeEl.innerHTML + '</span>';
                                            }

                                            if (!priceHtml && nameEl) {
                                                var rawText = item.innerText || '';
                                                var currencyMatches = rawText.match(/[\d.,]+(?:[ ]?(?:SAR|ر\.س|رس|SAR))/gi);
                                                if (currencyMatches && currencyMatches.length > 0) {
                                                    priceHtml = '<span style="font-weight: 600;">' + currencyMatches[0] + '</span>';
                                                    if (currencyMatches.length > 1) {
                                                        priceHtml += ' <del style="color: #b0b0b0;">' + currencyMatches[1] + '</del>';
                                                    }
                                                } else {
                                                    // VISUAL FALLBACK
                                                    priceHtml = '<div style="display: flex; align-items: center; gap: 8px;">' +
                                                        '<span style="font-weight: bold; font-size: 16px;">1000 SAR</span>' +
                                                        '<del style="color: #b0b0b0; font-size: 14px;">2000 SAR</del>' +
                                                        '<span class="discount-badge" style="background: #111; color: #fff; padding: 4px 8px; font-size: 12px; font-weight: 500;">30% Off</span>' +
                                                        '</div>';
                                                }
                                            }

                                            var isChecked = checkbox && checkbox.checked;

                                            var slide = document.createElement('div');
                                            slide.className = 'swiper-slide bundle-slide-card';

                                            slide.innerHTML =
                                                '<div class="bundle-card-inner">' +
                                                '<div class="bundle-card-left">' +
                                                '<img src="' + img.src + '" alt="' + (img.alt || '') + '" loading="lazy" decoding="async">' +
                                                '</div>' +
                                                '<div class="bundle-card-right">' +
                                                '<div class="bundle-card-details">' +
                                                '<h5 class="bundle-card-name">' + (nameEl ? nameEl.textContent : '') + '</h5>' +
                                                (optionsHtml ? '<div class="bundle-card-swatches">' + optionsHtml + '</div>' : '') +
                                                '<div class="bundle-card-price">' + priceHtml + '</div>' +
                                                '</div>' +
                                                '<button type="button" class="bundle-card-btn ' + (isChecked ? 'is-added' : '') + '" data-index="' + index + '">' +
                                                (isChecked ? ADDED_TEXT : ADD_TEXT) +
                                                '</button>' +
                                                '</div>' +
                                                '</div>';

                                            var btn = slide.querySelector('.bundle-card-btn');
                                            btn.addEventListener('click', function (e) {
                                                e.preventDefault();
                                                if (checkbox) {
                                                    checkbox.click();
                                                    var newState = checkbox.checked;
                                                    btn.classList.toggle('is-added', newState);
                                                    btn.textContent = newState ? ADDED_TEXT : ADD_TEXT;
                                                }
                                            });

                                            wrapper.appendChild(slide);
                                        });

                                        swiperContainer.style.display = 'block';

                                        if (window.Swiper) {
                                            if (swiperInstance) {
                                                swiperInstance.destroy(true, true);
                                            }
                                            swiperInstance = new Swiper('.bundle-swiper-container', {
                                                slidesPerView: 'auto',
                                                spaceBetween: 24,
                                                scrollbar: {
                                                    el: '.bundle-swiper-scrollbar',
                                                    draggable: true,
                                                    hide: false,
                                                },
                                            });
                                        }
                                    }

                                    function waitAndBuild() {
                                        var muiContainer = document.querySelector('.bundle-mui-hidden');
                                        if (!muiContainer) return;

                                        var observer = new MutationObserver(function (mutations, obs) {
                                            var items = muiContainer.querySelectorAll('.dynamic-bundle-item');
                                            if (items.length > 0) {
                                                buildSlider();
                                            }
                                        });
                                        observer.observe(muiContainer, { childList: true, subtree: true });

                                        var items = muiContainer.querySelectorAll('.dynamic-bundle-item');
                                        if (items.length > 0) {
                                            buildSlider();
                                        }

                                        setTimeout(buildSlider, 1500);
                                        setTimeout(buildSlider, 3000);
                                        setTimeout(buildSlider, 5000);
                                    }

                                    if (document.readyState === 'loading') {
                                        document.addEventListener('DOMContentLoaded', waitAndBuild);
                                    } else {
                                        waitAndBuild();
                                    }
                                })();
                            </script>
                            {% endif %}



                            {# 11. Purchase controls, or stock alert email when unavailable #}
                            <div
                                class="product-buttons pdp-order-purchase {% if can_buy %}d-block{% else %}d-none{% endif %}">
                                <div class="select-quantity-div">
                                    <div class="pdp-purchase-desktop-flex mt-3">
                                        <!-- Price (shown on mobile, hidden on desktop) -->
                                        <div class="pdp-purchase-price d-md-none">
                                            <h2 class="product-formatted-price theme-text-primary m-0"
                                                style="font-size: 20px; font-weight: 600; line-height: 1;">
                                                {% if product.selected_product.formatted_sale_price %}
                                                    {{ product.selected_product.formatted_sale_price }}
                                                {% else %}
                                                    {{ product.selected_product.formatted_price }}
                                                {% endif %}
                                            </h2>
                                            {% if product.selected_product.formatted_sale_price %}
                                            <del class="product-formatted-price-old text-muted m-0"
                                                style="font-size: 14px; font-weight: 600; line-height: 1;">
                                                {{ product.selected_product.formatted_price }}
                                            </del>
                                            {% else %}
                                            <del class="product-formatted-price-old text-muted m-0 d-none"></del>
                                            {% endif %}
                                        </div>

                                        <!-- Quantity Stepper -->
                                        <div class="quantity-stepper-container d-flex align-items-center"
                                            style="flex: 0 0 auto; height: 100%; margin: 0; border-radius: var(--border-radius-none);">
                                            <button type="button" class="btn-qty btn-qty-minus h-100 px-3"
                                                aria-label="Decrease quantity">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                                                    xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M6 12L18 12" stroke="currentColor" stroke-width="2"
                                                        stroke-linecap="round" stroke-linejoin="round" />
                                                </svg></button>
                                            <span class="qty-display px-2"
                                                style="font-size: 1rem; font-weight: 500;">1</span>
                                            <button type="button" class="btn-qty btn-qty-plus h-100 px-3"
                                                aria-label="Increase quantity"><svg width="20" height="20"
                                                    viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M6 12H18M12 6V18" stroke="currentColor" stroke-width="2"
                                                        stroke-linecap="round" stroke-linejoin="round" />
