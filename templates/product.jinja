        }

        setPdpVisibility('.div-product-weight', false);
        setPdpVisibility('.div-product-sku', false);

        updateProductImages(selected_product);
    }
        }

    function updateProductImages(selected_product) {
        var selectedMedia = selected_product && Array.isArray(selected_product.media)
            ? selected_product.media
            : [];
        var completeGalleryMedia = buildCompleteProductGalleryMedia(selectedMedia);
        var selectedImageData = getVariantImageData(selected_product);
        var currentGallerySignature = getProductGalleryMediaSignature(productImages);
        var nextGallerySignature = getProductGalleryMediaSignature(completeGalleryMedia);
        var currentSliderElement = document.getElementById('product-images-swiper');
        var currentGallerySwiper = productGallerySwiper || (currentSliderElement && currentSliderElement.swiper);

        if (currentGallerySwiper && !currentGallerySwiper.destroyed
            && currentGallerySignature === nextGallerySignature) {
            productImages = completeGalleryMedia;
            if (selectedImageData) {
                slideProductGalleryToImage(selectedImageData.galleryUrl, 0);
            }
            return;
        }

        if (completeGalleryMedia.length > 0) {
            setPdpVisibility('.product-images-carousel', true);
            setPdpVisibility('.product-images-carousel-thumbs', true);
            setPdpVisibility('.product-images-empty', false);

            var sliderElement = document.getElementById('product-images-swiper');
            if (sliderElement && window.themeSwiper) {
                window.themeSwiper.destroy(sliderElement);
            }
            productGallerySwiper = null;
            var thumbsSliderElement = document.getElementById('product-images-thumbs-swiper');
            if (thumbsSliderElement && window.themeSwiper) {
                window.themeSwiper.destroy(thumbsSliderElement);
            }
            productThumbsSwiper = null;

            $('.product-images-carousel').addClass('product-images-carousel-init');

            productImages = completeGalleryMedia;

            // Rebuild the existing wrappers directly to avoid jQuery data cleanup issues in Safari.
            var slidesElement = document.querySelector('#product-images-swiper .swiper-wrapper');
            if (slidesElement) { slidesElement.innerHTML = ''; }
            var thumbsEl = document.querySelector('.product-images-carousel-thumbs .swiper-wrapper');
            if (thumbsEl) { thumbsEl.innerHTML = ''; }

            for (var z = 0; z < productImages.length; z++) {
                var prImage = productImages[z];
                var prMediaImage = getProductMediaImage(prImage) || {};
                var prFullImage = prMediaImage.full_size || prMediaImage.large || prMediaImage.medium || prMediaImage.url || '';
                var prThumbImage = prMediaImage.medium || prFullImage;
                var imageHtml = '<div class="swiper-slide">' +
                    '<div class="box-1-1">' +
                    '<div class="content">' +
                    '<a class="image-link" style="display:block; width: 100%; height: 100%;">' +
                    '<img src="' + prFullImage + '" class="carousel-img" loading="' + (z === 0 ? 'eager' : 'lazy') + '" decoding="async" fetchpriority="' + (z === 0 ? 'high' : 'low') + '" alt="' + (selected_product && selected_product.name ? selected_product.name : '') + '">';

                if (prImage.provider && prImage.link) {
                    imageHtml += '<img id="main-video-icon" class="play-icon" src="{{ "video-play.svg" | asset_url }}" alt="play" loading="lazy" decoding="async" onclick="showIframe(this, \'' + prImage.link.replace(/'/g, '\\\'') + '\')"/>';
                }

                imageHtml += '</a>' +
                    '<div class="iframe-video pt-1 d-none">' +
                    '<a id="iframe-close-btn" type="button" class="text-white btn btn-none grow" onClick="hideIframe(this)">X</a>' +
                    '<iframe width="100%" height="100%" src="" loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="max-width: 100%">' +
                    '</iframe>' +
                    '</div>' +
                    '</div>' +
                    '</div>' +
                    '</div>';

                if (slidesElement) {
                    slidesElement.insertAdjacentHTML('beforeend', imageHtml);
                }

                var thumbHtml = '<div class="swiper-slide">' +
                    '<div class="box-1-1">' +
                    '<div class="content">' +
                    '<a class="d-flex align-items-center justify-content-center thumb-image-a" data-index="' + z + '" style="width: 100%; height: 100%;">' +
                    '<img src="' + prThumbImage + '" data-index="' + z + '" loading="lazy" decoding="async">';

                if (prImage.provider && prImage.link) {
                    thumbHtml += '<img id="video-play-icon" class="play-icon" src="{{ "video-play.svg" | asset_url }}" alt="play" data-index="' + z + '" loading="lazy" decoding="async">';
                }

                thumbHtml += '</a>' +
                    '</div>' +
                    '</div>' +
                    '</div>';

                if (thumbsEl) {
                    thumbsEl.insertAdjacentHTML('beforeend', thumbHtml);
                }
            }

            requestAnimationFrame(function () {
                var selectedImageIndex = selectedImageData
                    ? getProductGalleryImageIndex(productImages, selectedImageData.galleryUrl)
                    : 0;
                initProductGallery(productImages, Math.max(0, selectedImageIndex));
            });
        } else {
            setPdpVisibility('.product-images-carousel', false);
            setPdpVisibility('.product-images-carousel-thumbs', false);
            setPdpVisibility('.product-images-empty', true);
        }
    }

    $('#product-description-a').click(function (event) {
        event.preventDefault();

        var scrollOffset;
        if (window.matchMedia('(max-width: 768px)').matches) {
            scrollOffset = 15;
        } else {
            scrollOffset = 150;
        }

        var targetElement = $($(this).attr('href'));
        if (targetElement.length) {
            $('html, body').animate({
                scrollTop: targetElement.offset().top - scrollOffset
            }, 820);
        }
    });

    function addReviewButtonChecks() {
        if (!window.customerAuthState || !window.customerAuthState.isAuthenticated) {
            setPdpVisibility('#add-review-btn', false);
            setPdpVisibility('#add-review-link', true);
            $('#add-review-link').attr('href', '/auth/login?redirect_to=' + window.location.pathname.replace('/', ''));
            $('#add-review-link').on('click', function (e) {
                e.preventDefault();
                handleLoginAction(window.location.pathname.replace('/', ''));
                return false;
            });
        }
    }

    $(document).ready(function () {
        if (productImages && productImages.length > 0) {
            initProductGallery(productImages);
        }
        if (customerWishlistIds && Array.isArray(customerWishlistIds)) {
            fillWishlistItems(customerWishlistIds.map(function (id) { return { id: id }; }));
        }
    });

    $(document).on('click', '.thumb-image-a, #video-play-icon', function (event) {
        var dataIndex = parseInt($(event.currentTarget).attr('data-index'), 10);

        if (!isNaN(dataIndex) && productGallerySwiper && !productGallerySwiper.destroyed) {
            productGallerySwiper.slideTo(dataIndex);
            syncProductGalleryThumbnail(dataIndex);
        }
    });

    $(document).on('click', '#product-images-swiper .image-link :not(#main-video-icon)', function (event) {
        $('.pswp').removeClass('d-hide');
        $('.app').addClass('d-hide');

        var images = productImages.map(function (image) {
            return image.image && image.image.full_size ? image.image.full_size : '';
        }).filter(function (url) { return url; });

        var currentIndex = productGallerySwiper && !productGallerySwiper.destroyed
            ? productGallerySwiper.activeIndex
            : 0;
        if (typeof openPhotoSwiper === 'function') {
            openPhotoSwiper(images, currentIndex);
        }
    });

    $(document).on('click', '.variant-image-wrapper a', function (event) {
        $('.pswp').removeClass('d-hide');
        $('.app').addClass('d-hide');

        var elm = event.currentTarget;
        var varId = $(elm).attr('data-link-var-id');
        var images = [];

        $("div[data-var-id='" + varId + "'] img").each(function () {
            var imageUrl = $(this).attr('data-image-url');
            if (imageUrl) {
                images.push(imageUrl);
            }
        });

        var index = parseInt($(elm).attr('data-index')) || 0;
        if (typeof openPhotoSwiper === 'function') {
            openPhotoSwiper(images, index);
        }
    });

    function syncProductGalleryThumbnail(index) {
        var thumbLinks = document.querySelectorAll('.product-images-carousel-thumbs .thumb-image-a');

        thumbLinks.forEach(function (link) {
            link.classList.toggle('selected', parseInt(link.getAttribute('data-index'), 10) === index);
        });

        if (productThumbsSwiper && !productThumbsSwiper.destroyed) {
            productThumbsSwiper.slideTo(index);
        }
    }

    function initProductGalleryThumbs() {
        var thumbsElement = document.getElementById('product-images-thumbs-swiper');

        if (!thumbsElement || !window.themeSwiper) {
            return null;
        }

        productThumbsSwiper = window.themeSwiper.init(thumbsElement, {
            slidesPerView: 5,
            slidesPerGroup: 1,
            spaceBetween: 15,
            freeMode: true,
            watchSlidesProgress: true,
            navigation: false,
            pagination: false
        });

        return productThumbsSwiper;
    }

    function initProductGallery(productImages, initialSlide) {
        if (!productImages || !Array.isArray(productImages)) {
            return null;
        }

        var sliderElement = document.getElementById('product-images-swiper');
        if (!sliderElement || !window.themeSwiper) {
            var fallbackGallery = document.querySelector('.product-images-carousel');
            if (fallbackGallery) {
                fallbackGallery.classList.remove('product-images-carousel-init');
                replayPdpAnimation(fallbackGallery);
            }
            return null;
        }

        var hasMultipleImages = productImages.length > 1;
        document.querySelectorAll('.product-gallery-control, .product-gallery-pagination').forEach(function (control) {
            setPdpVisibility(control, hasMultipleImages);
        });
        initProductGalleryThumbs();

        productGallerySwiper = window.themeSwiper.init(sliderElement, {
            slidesPerView: 1,
            slidesPerGroup: 1,
            initialSlide: Number.isInteger(initialSlide) ? initialSlide : 0,
            loop: false,
            autoplay: false,
            navigation: hasMultipleImages,
            pagination: hasMultipleImages,
            on: {
                init: function (swiper) {
                    var gallery = document.querySelector('.product-images-carousel');
                    if (gallery) {
                        gallery.classList.remove('product-images-carousel-init');
                        replayPdpAnimation(gallery);
                        preparePdpImages(gallery);
                    }
                    syncProductGalleryThumbnail(swiper.activeIndex);
                    setTimeout(function () {
                        playProductSlideVideo(swiper.slides[swiper.activeIndex]);
                    }, 250);
                },
                slideChange: function (swiper) {
                    syncProductGalleryThumbnail(swiper.activeIndex);
                },
                slideChangeTransitionStart: function (swiper) {
                    stopProductSlideVideo(swiper.slides[swiper.previousIndex]);
                },
                slideChangeTransitionEnd: function (swiper) {
                    playProductSlideVideo(swiper.slides[swiper.activeIndex]);
                }
            }
        });

        return productGallerySwiper;
    }

    function openPhotoSwipe(productImages, index) {
        if (!productImages || !Array.isArray(productImages) || productImages.length === 0) {
            return;
        }

        var pswpElement = document.querySelectorAll('.pswp')[0];
        if (!pswpElement) {
            return;
        }

        // build items array
        var items = productImages.map(function (image) {
            return {
                src: image,
                w: 1200,
                h: 900
            };
        });

        var options = {
            history: false,
            focus: false,
            showAnimationDuration: 0,
            hideAnimationDuration: 0,
            index: parseInt(index) || 0
        };

        if (typeof PhotoSwipe !== 'undefined' && typeof PhotoSwipeUI_Default !== 'undefined') {
            var gallery = new PhotoSwipe(pswpElement, PhotoSwipeUI_Default, items, options);

            gallery.listen('close', function () {
                $('.pswp').addClass('d-hide');
                $('.app').removeClass('d-hide');
            });

            gallery.init();
        }
    }

    function showRelatedProducts() {
        var slider = document.getElementById('related-products');

        if (slider && window.themeSwiper) {
            window.themeSwiper.initResponsive(slider, {
                slidesPerView: 5,
                slidesPerGroup: 5,
                loop: false,
                autoplay: false,
                navigation: true,
                pagination: false
            }, {
                minWidth: 768
            });
        }
    }

    document.addEventListener('zid-customer-fetched', function (event) {
        var customer = event.detail.customer;
        if (customer && customer.mobile) {
            $('.send-notify-name').val(customer.name || '');
            $('.send-notify-email').val(customer.email || '');
            $('.send-notify-country-key').val(customer.mobile.substring(0, 3) || '966');
            $('.send-notify-phone').val(customer.mobile.substring(3) || '');
        }
    });

    // Product Image Video
    function getIframeLink(videoLink) {
        if (!videoLink || typeof videoLink !== 'string') {
            return null;
        }

        const videoIdMatch = videoLink.match(
            /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?|.*[?&]v=)|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
        );

        if (videoIdMatch && videoIdMatch[1]) {
            const videoLinkId = videoIdMatch[1];
            return 'https://www.youtube.com/embed/' + videoLinkId + '?autoplay=1&enablejsapi=1';
        }

        return null;
    }

    function showIframe(elm, imageVideoSrc) {
        if (!elm || !imageVideoSrc) {
            return;
        }

        const iframeLink = getIframeLink(imageVideoSrc);
        if (!iframeLink) {
            return;
        }

        const iframeElem = $(elm).parent(".image-link").siblings(".iframe-video").children("iframe");
        $(elm).parent(".image-link").siblings(".iframe-video").removeClass("d-none");

        if ($(iframeElem).attr("src") !== iframeLink) {
            $(iframeElem).attr("src", iframeLink);
        }
    }

    function hideIframe(elm) {
        if (!elm) {
            return;
        }

        $(elm).parent(".iframe-video").addClass("d-none");
        $(elm).siblings("iframe").attr("src", "");
    }

    function stopProductSlideVideo(slide) {
        if (!slide) {
            return;
        }

        var iframeContainer = slide.querySelector('.iframe-video');
        if (iframeContainer) {
            $(iframeContainer).addClass('d-none');
            $(iframeContainer).children('iframe').attr('src', '');
        }
    }

    function playProductSlideVideo(slide) {
        if (!slide) {
            return;
        }

        var playIcon = slide.querySelector('.image-link #main-video-icon');
        if (playIcon) {
            playIcon.click();
        }
    }

    // Luxury Minimal JS: visual-only enhancements scoped to PDP.
    function getLuxuryProductPage() {
        return $('.luxury-product-page');
    }

    function dispatchNativeQuantityEvents($field) {
        if (!$field || !$field.length) {
            return;
        }

        $field.trigger('input').trigger('change');

        var nativeField = $field.get(0);
        if (nativeField && typeof Event === 'function') {
            nativeField.dispatchEvent(new Event('input', { bubbles: true }));
            nativeField.dispatchEvent(new Event('change', { bubbles: true }));
        }
    }

    function syncLuxuryQtyDisplay() {
        var $page = getLuxuryProductPage();
        var $qtyInput = $page.find('#product-quantity');
        var $qtyDisplay = $page.find('.qty-display');
        var $minusButton = $page.find('.btn-qty-minus');
        var $plusButton = $page.find('.btn-qty-plus');

        if (!$qtyInput.length || !$qtyDisplay.length) {
            return;
        }

        var currentVal = parseInt($qtyInput.val(), 10) || 1;
        var maxVal = parseInt($qtyInput.find('option:last').val(), 10) || currentVal;
        var isDisabled = $qtyInput.prop('disabled') || maxVal <= 0;

        if (currentVal > maxVal) {
            currentVal = maxVal;
            $qtyInput.val(currentVal);
        }

        if (currentVal < 1) {
            currentVal = 1;
            $qtyInput.val(currentVal);
        }

        $qtyDisplay.text(currentVal);
        $minusButton.prop('disabled', isDisabled || currentVal <= 1);
        $plusButton.prop('disabled', isDisabled || currentVal >= maxVal);
    }

    function initLuxuryHexSwatches() {
        var $page = getLuxuryProductPage();
        // Strict standalone HEX match only: #RGB or #RRGGBB.
        var hexRegex = /(?:^|\s)(#(?:[A-Fa-f0-9]{6}|[A-Fa-f0-9]{3}))(?:\s|$)/;

        $page.find('.size-box #product-variants-options ul li').each(function () {
            var $li = $(this);
            var $link = $li.find('a, span, label, button').first();

            if ($li.hasClass('variant-image-option') || $li.find('.variant-option-image').length) {
                $li.removeClass('circular-swatch');
                $li.css('--swatch-color', '');
                return;
            }

            var rawText = $.trim($link.text() || $li.text());
            var match = rawText.match(hexRegex);

            if (!match) {
                return;
            }

            var hexColor = match[1];
            var cleanName = $.trim(rawText.replace(hexRegex, ' ')).replace(/\s{2,}/g, ' ');

            $li.addClass('circular-swatch');
            $li.attr('data-option-name', cleanName);
            $li.attr('data-hex-color', hexColor);
            $li.css('--swatch-color', hexColor);

            if ($link.length) {
                // Keep the original text node intact for Zid bindings; hide it visually through CSS only.
                $link.attr('aria-label', cleanName || hexColor);
                $link.attr('title', cleanName || hexColor);
            }
        });

        $page.find('.size-box #product-variants-options .form-group').each(function () {
            var $group = $(this);
            var $label = $group.find('label').first();
            var hasSwatches = $group.find('ul li.circular-swatch').length > 0;

            if (!hasSwatches) {
                return;
            }

            if (!$group.find('.selected-swatch-name').length) {
                $('<span class="selected-swatch-name"></span>').insertAfter($label.length ? $label : $group.children().first());
            }
        });

        syncSelectedSwatchLabels();
    }

    function syncSelectedSwatchLabels() {
        var $page = getLuxuryProductPage();

        $page.find('.size-box #product-variants-options .form-group').each(function () {
            var $group = $(this);
            var $labelTarget = $group.find('.selected-swatch-name').first();

            if (!$labelTarget.length) {
                return;
            }

            var $selected = $group.find('li.circular-swatch.active, li.circular-swatch.selected').first();
            if (!$selected.length) {
                $selected = $group.find('li.circular-swatch').filter(function () {
                    return $(this).find('input:checked').length > 0 || $(this).find('a.active, a.selected').length > 0;
                }).first();
            }

            var cleanName = $selected.attr('data-option-name') || '';
            $labelTarget.text(cleanName);
        });
    }

    $(document).ready(function () {
        var $page = getLuxuryProductPage();

        if (!$page.length) {
            return;
        }

        // 1. Accordion Toggle
        $page.on('click', '.js-accordion-toggle', function () {
            var targetSelector = $(this).data('target');
            var $target = $page.find(targetSelector);
            var $icon = $(this).find('.icon-toggle');

            if (!$target.length) {
                return;
            }

            var willOpen = !$target.is(':visible');
            if ($icon.length && !pdpReducedMotion && typeof $icon.get(0).animate === 'function') {
                $icon.get(0).animate([
                    { opacity: 1, transform: 'rotate(0deg) scale(1)' },
                    { opacity: 0.35, transform: 'rotate(90deg) scale(0.7)' },
                    { opacity: 1, transform: 'rotate(180deg) scale(1)' }
                ], {
                    duration: 760,
                    easing: 'cubic-bezier(0.22, 1, 0.36, 1)'
                });
            }

            $target.stop(true, true).slideToggle(820, function () {
                $icon.text(willOpen ? '-' : '+');
                $icon.toggleClass('is-open', willOpen);
            });
        });

        // 2. Reviews / Questions Tabs Toggle
        $page.on('click', '.tabs-minimal-header .tab-btn', function () {
            var targetSelector = $(this).data('target');
            var $target = $page.find(targetSelector);

            if (!$target.length) {
                return;
            }

            animatePdpTabSwitch($page.get(0), $target.get(0), this);
        });

        // 3. Hex Color Swatches: visual enhancement only; original variant DOM/bindings stay untouched.
        initLuxuryHexSwatches();
        $page.on('click', '.size-box #product-variants-options li.circular-swatch, .size-box #product-variants-options li.circular-swatch a', function () {
            var $clickedSwatch = $(this).closest('li.circular-swatch');
            window.setTimeout(function () {
                syncSelectedSwatchLabels();
                // Keep image/variant sync owned by Zid/native handlers; no manual variant mutation here.
            }, 0);
        });

        if (window.MutationObserver) {
            var variantsRoot = $page.find('.size-box #product-variants-options').get(0);
            if (variantsRoot) {
                var swatchObserver = new MutationObserver(function () {
                    window.requestAnimationFrame(function () {
                        applyVariantOptionImages();
                        initLuxuryHexSwatches();
                        syncSelectedSwatchLabels();
                    });
                });
                swatchObserver.observe(variantsRoot, { childList: true, subtree: true, attributes: true, attributeFilter: ['class'] });
            }
        }

        // 4. Quantity Stepper Logic
        $page.on('click', '.btn-qty-minus, .btn-qty-plus', function () {
            var $qtyInput = $page.find('#product-quantity');

            if (!$qtyInput.length || $qtyInput.prop('disabled')) {
                return;
            }

            var currentVal = parseInt($qtyInput.val(), 10) || 1;
            var maxVal = parseInt($qtyInput.find('option:last').val(), 10) || currentVal;
            var isIncrement = $(this).hasClass('btn-qty-plus');
            var newVal = isIncrement ? currentVal + 1 : currentVal - 1;

            newVal = Math.max(1, Math.min(maxVal, newVal));

            if (newVal !== currentVal) {
                $qtyInput.val(newVal);
                dispatchNativeQuantityEvents($qtyInput);
            }

            syncLuxuryQtyDisplay();
        });

        $page.on('input change', '#product-quantity', function () {
            syncLuxuryQtyDisplay();
            if (typeof updatePriceWithQuantity === 'function') {
                updatePriceWithQuantity();
            }
        });

        syncLuxuryQtyDisplay();

        if (typeof window.pdpInitMobileCart === "function") window.pdpInitMobileCart(document.body);
        if (typeof window.pdpInitReels === "function") window.pdpInitReels(document.body);
        if (typeof window.pdpInitQuestionMessages === "function") window.pdpInitQuestionMessages(document.body);
    });

</script>
<!-- Reels Modal -->
<div id="reels-modal" class="reels-modal-container">
    <div class="reels-modal-background" id="reels-modal-bg">
        <div class="reels-modal-content">
            <button type="button" id="reels-close-btn" class="reels-close-btn">&times;</button>
            <button type="button" id="reels-mute-btn" class="reels-mute-btn" aria-label="Toggle mute">
                <!-- SVG for unmuted (Volume Up) -->
                <svg id="icon-unmuted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="d-none">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
                </svg>
                <!-- SVG for muted (Volume Off) -->
                <svg id="icon-muted" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <line x1="23" y1="9" x2="17" y2="15"></line>
                    <line x1="17" y1="9" x2="23" y2="15"></line>
                </svg>
            </button>
            <div class="reels-progress-container" id="reels-progress-container"></div>
            <div class="reels-video-container">
                <video id="reels-video" playsinline webkit-playsinline muted preload="none"></video>

                <button type="button" class="reels-nav-btn prev" id="reels-prev-btn" aria-label="Previous">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                </button>
                <button type="button" class="reels-nav-btn next" id="reels-next-btn" aria-label="Next">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                </button>

                <div class="reels-nav-zone center-zone" id="reels-center-zone"></div>

                <div class="reels-loader d-none" id="reels-loader">
                    <img src="{{ 'spinner.gif' | asset_url }}" width="30" height="30" loading="lazy" decoding="async"
                        alt="" />
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}