    function productOptionsChanged(selected_product) {
        var hasPreorder = $('[data-has-preorder]').attr('data-has-preorder') === 'true';
        var canPreorder = $('[data-can-preorder]').attr('data-can-preorder') === 'true';
        var stockBehavior = $('[data-stock-behavior]').attr('data-stock-behavior') || '';

        if (selected_product) {
            $('#product-id').val(selected_product.id);
            $('.send-notify-product-id').val(selected_product.id);

            var isBuyable;
            if (stockBehavior === 'IN_STOCK_ONLY') {
                isBuyable = selected_product.in_stock;
            } else {
                isBuyable = selected_product.in_stock || canPreorder;
            }

            if (isBuyable) {
                // Selected a variant that can be ordered (in stock OR preorder allowed).
                if (selected_product.formatted_sale_price) {
                    baseFormattedPrice = selected_product.formatted_sale_price;
                    baseFormattedOldPrice = selected_product.formatted_price;
                    updatePriceWithQuantity();
                    $('.product-formatted-price-discount').html('{{ _("Discount") }}' + ' ' + selected_product.discount_percentage + '%');
                } else {
                    baseFormattedPrice = selected_product.formatted_price;
                    baseFormattedOldPrice = '';
                    updatePriceWithQuantity();
                    $('.product-formatted-price-discount').html('');
                }
                updateBodyCartPadding();

                if (selected_product.weight && selected_product.weight.value) {
                    setPdpVisibility('.div-product-weight', true);
                    $('.div-product-weight .product-weight, .div-product-weight .product-weight-value')
                        .html(selected_product.weight.value + ' ' + selected_product.weight.unit);
                } else {
                    setPdpVisibility('.div-product-weight', false);
                }

                if (selected_product.sku) {
                    setPdpVisibility('.div-product-sku', true);
                    $('.div-product-sku .product-sku, .div-product-sku .product-sku-value').html(selected_product.sku);
                } else {
                    setPdpVisibility('.div-product-sku', false);
                }

                {% if store.settings.products.low_stock_label_enabled %}
                var store_low_stock_limit = {{ store.settings.products.low_stock_quantity_threshold }};
            var low_stock_message = '{{ _("Remaining %s only") }}';

            if (!selected_product.is_infinite && selected_product.quantity < store_low_stock_limit) {
                setPdpVisibility('.low-quantity-section', true, 'd-inline-block');
                $('.low-quantity-section .low-quantity').html(low_stock_message.replace('%s', selected_product.quantity));
            } else {
                setPdpVisibility('.low-quantity-section', false);
            }
            {% endif %}

            var selectQuantity = '';

            if (selected_product.is_infinite) {
                selected_product.quantity = 100;
            }

            if (selected_product.quantity > 0 || canPreorder) {
                setPdpVisibility('.select-quantity-div', true);
                var quantityMax;
                if (canPreorder && selected_product.quantity <= 0) {
                    quantityMax = 100;
                } else if (selected_product.quantity > 100) {
                    quantityMax = 100;
                } else {
                    quantityMax = selected_product.quantity;
                }
                selectQuantity = '<option value="1" selected>1</option>';
                for (var i = 2; i <= quantityMax; i++) {
